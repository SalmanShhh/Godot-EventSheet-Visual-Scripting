[sub_resource type="Resource" id="Resource_vpfg4"]
script = ExtResource("1_28gw5")
text = "[b]Platformer-Shooter[/b] — the new Platformer + Weapon Kit packs working together. Run with A/D, jump with Up (double jump + coyote time + variable height from the Platformer pack), and hold Space to shoot (fire-rate, ammo and auto-reload from the Weapon Kit). Shots destroy the red targets drifting in from the right."

[sub_resource type="Resource" id="Resource_1lxfq"]
script = ExtResource("2_y23yn")
code = "if Input.is_action_just_pressed(&\"ui_up\"):
	$Player/PlatformerMovement.jump()
if Input.is_action_just_released(&\"ui_up\"):
	$Player/PlatformerMovement.jump_released()"

[sub_resource type="Resource" id="Resource_l5ijk"]
script = ExtResource("6_d8wcs")
trigger_provider_id = "Core"
trigger_id = "OnPhysicsProcess"
