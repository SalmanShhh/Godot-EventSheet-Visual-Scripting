[sub_resource type="Resource" id="Resource_g2xko"]
script = ExtResource("2_y23yn")
code = "for __shot in get_tree().get_nodes_in_group(\"shots\"):
	for __target in get_tree().get_nodes_in_group(\"targets\"):
		if is_instance_valid(__shot) and is_instance_valid(__target) and __shot.global_position.distance_to(__target.global_position) < 42.0:
			__shot.queue_free()
			__target.queue_free()
			score += 1
			break
for __node in get_tree().get_nodes_in_group(\"shots\") + get_tree().get_nodes_in_group(\"targets\"):
	if __node.global_position.x < -60.0 or __node.global_position.x > 1300.0:
		__node.queue_free()"

