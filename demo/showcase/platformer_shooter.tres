[sub_resource type="Resource" id="Resource_g2xko"]
script = ExtResource("2_cdguq")
ace_id = "SpawnSceneFull"
params = {
"group": "\"shots\"",
"path": "\"res://demo/showcase/shot.tscn\"",
"position": "$Player.position + Vector2(32.0 * $Player/PlatformerMovement.facing_direction(), -6.0)",
"rotation": "0.0 if $Player/PlatformerMovement.facing_direction() >= 0 else 180.0"
}
codegen_template = "var __spawn_shot = load({path}).instantiate()
__spawn_shot.position = {position}
__spawn_shot.rotation_degrees = {rotation}
add_child(__spawn_shot)
if {group} != \"\": __spawn_shot.add_to_group({group})"

