[sub_resource type="Resource" id="Resource_r8eu4"]
script = ExtResource("2_cdguq")
code = "var __target = load(\"res://demo/showcase/target.tscn\").instantiate()
__target.position = Vector2(1240.0, randf_range(120.0, 540.0))
__target.rotation_degrees = 180.0
add_child(__target)
__target.add_to_group(\"targets\")"

[sub_resource type="Resource" id="Resource_vc2a2"]
script = ExtResource("3_sjy6o")
ace_id = "EveryXSeconds"
params = {
"seconds": "1.5"
}
codegen_template = "__every_ps_spawn >= maxf(1.5, 0.001)"
member_declaration = "var __every_ps_spawn: float = 0.0"
codegen_prelude = "__every_ps_spawn += delta"
codegen_on_true = "__every_ps_spawn = fmod(__every_ps_spawn, maxf(1.5, 0.001))"

