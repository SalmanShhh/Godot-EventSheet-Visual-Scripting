[sub_resource type="Resource" id="Resource_o38o8"]
script = ExtResource("1_2luld")
text = "[b]Carousel of Juice[/b] — 8 tiles sine-sway and spring-pop on the beat (one reused juice_tile function). A runtime-toggleable Juice group plus an if/elif/else keypress chain re-skin the board: [b]ui_accept[/b] starts the party, [b]ui_cancel[/b] calms it. Watch beat/intensity stream in Live Values."

[sub_resource type="Resource" id="Resource_dd4l4"]
script = ExtResource("2_i1ys7")
ace_id = "AddVar"
params = {
"amount": "1",
"var_name": "beat"
}
codegen_template = "{var_name} += {amount}"

[sub_resource type="Resource" id="Resource_k3ipq"]
script = ExtResource("2_i1ys7")
ace_id = "CallFunction"
params = {
"args": "beat, intensity * 5.0",
"function_name": "juice_tile"
}
codegen_template = "{function_name}({args})"

[sub_resource type="Resource" id="Resource_58nhv"]
script = ExtResource("3_kccjq")
ace_id = "EveryXSeconds"
params = {
"seconds": "0.5"
}
codegen_template = "__every_beat_caro >= maxf(0.5, 0.001)"
member_declaration = "var __every_beat_caro: float = 0.0"
codegen_prelude = "__every_beat_caro += delta"
codegen_on_true = "__every_beat_caro = fmod(__every_beat_caro, maxf(0.5, 0.001))"

[sub_resource type="Resource" id="Resource_7vv6f"]
script = ExtResource("6_l76gw")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
conditions = Array[ExtResource("3_kccjq")]([SubResource("Resource_58nhv")])
actions = Array[Resource]([SubResource("Resource_dd4l4"), SubResource("Resource_k3ipq")])
event_uid = "3faf2b"

[sub_resource type="Resource" id="Resource_x8v5x"]
