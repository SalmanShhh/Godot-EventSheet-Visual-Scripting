[resource]
script = ExtResource("8_fn4y8")
host_class = "Node2D"
emit_live_values = true
custom_class_name = "ShowcaseV070"
addon_tags = PackedStringArray()
events = Array[Resource]([SubResource("Resource_qifx4"), SubResource("Resource_stu2x"), SubResource("Resource_8jxsx"), SubResource("Resource_b83h0")])
variables = {
"pulse_scale": {
"attributes": {
"clamp": true,
"range": {
"max": "3",
"min": "1",
"step": "0.05"
},
"tooltip": "How hard the spring kicks."
},
"default": 1.35,
"exported": true,
"type": "float"
},
"pulses": {
"attributes": {
"range": {
"max": "999",
"min": "0",
"step": "1"
},
"tooltip": "How many juice pulses have fired (watch it in Live Values — and edit it!)."
},
"default": 0,
"exported": true,
"type": "int"
}
}
