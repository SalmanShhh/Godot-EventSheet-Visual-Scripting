[sub_resource type="Resource" id="Resource_qifx4"]
script = ExtResource("1_5cbq2")
text = "[b]v0.7.0 showcase[/b] — the runtime-toggleable [i]Juice[/i] group pulses the host every 2s (Spring + Tween). Press [b]ui_accept[/b] for a manual pulse, [b]ui_cancel[/b] to tween home — an if/elif chain authored as Else rows. Open showcase_v070.gd as a sheet and run Tools → Lift Report: every block explains what lifted and why the rest stayed code."

[sub_resource type="Resource" id="Resource_vudrq"]
script = ExtResource("2_t2r3h")
code = "pulses += 1
$SpringBehavior.set_spring(\"__scale\", 1.0)
$SpringBehavior.spring_host_scale(1.0)
$SpringBehavior.add_impulse(\"__scale\", pulse_scale * 4.0)
$TweenBehavior.tween_rotation(rotation_degrees + 90.0, 0.6)"

[sub_resource type="Resource" id="Resource_hb2ra"]
script = ExtResource("3_vo2s3")
ace_id = "EveryXSeconds"
params = {
"seconds": "2.0"
}
codegen_template = "__every_5c0wca5e >= maxf(2.0, 0.001)"
member_declaration = "var __every_5c0wca5e: float = 0.0"
codegen_prelude = "__every_5c0wca5e += delta"
codegen_on_true = "__every_5c0wca5e = fmod(__every_5c0wca5e, maxf(2.0, 0.001))"

[sub_resource type="Resource" id="Resource_weabl"]
script = ExtResource("6_smp8l")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
conditions = Array[ExtResource("3_vo2s3")]([SubResource("Resource_hb2ra")])
actions = Array[Resource]([SubResource("Resource_vudrq")])
event_uid = "0c7dfb"

[sub_resource type="Resource" id="Resource_stu2x"]
script = ExtResource("7_n1xg4")
group_name = "Juice"
events = Array[Resource]([SubResource("Resource_weabl")])
group_uid = "61eb00"
custom_color = Color(0.55, 0.4, 0.85, 1)
runtime_toggleable = true

[sub_resource type="Resource" id="Resource_ii8li"]
script = ExtResource("2_t2r3h")
code = "pulses += 1
$SpringBehavior.add_impulse(\"__scale\", pulse_scale * 4.0)"

