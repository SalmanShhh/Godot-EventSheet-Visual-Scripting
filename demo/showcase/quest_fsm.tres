[sub_resource type="Resource" id="Resource_u1m31"]
script = ExtResource("5_bfrky")
ace_id = "AddVar"
params = {
"amount": "1",
"var_name": "tick"
}
codegen_template = "{var_name} += {amount}"

[sub_resource type="Resource" id="Resource_1qjyp"]
script = ExtResource("6_kpwkv")
match_expression = "quest_state"
branches_text = "QuestState.OFFERED:
	quest_state = QuestState.ACTIVE
	quest_advanced.emit(quest_state)
QuestState.ACTIVE:
	grant_item(\"gold\", 3)
	if quest_log.size() >= 3:
		quest_state = QuestState.COMPLETE
		quest_advanced.emit(quest_state)
_:
	pass"

[sub_resource type="Resource" id="Resource_0i65x"]
script = ExtResource("7_smcs3")
ace_id = "EveryXSeconds"
params = {
"seconds": "1.0"
}
codegen_template = "__every_quest >= maxf(1.0, 0.001)"
member_declaration = "var __every_quest: float = 0.0"
codegen_prelude = "__every_quest += delta"
codegen_on_true = "__every_quest = fmod(__every_quest, maxf(1.0, 0.001))"

[sub_resource type="Resource" id="Resource_3ypjf"]
script = ExtResource("9_lpwia")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
conditions = Array[ExtResource("7_smcs3")]([SubResource("Resource_0i65x")])
actions = Array[Resource]([SubResource("Resource_u1m31"), SubResource("Resource_1qjyp")])
event_uid = "00b366"

[sub_resource type="Resource" id="Resource_0j44r"]
script = ExtResource("10_teoow")
code = "$Icon/SpringBehavior.spring_host_scale(1.0)
$Icon/SpringBehavior.add_impulse(\"__scale\", 6.0)"

[sub_resource type="Resource" id="Resource_1w1ep"]
