[sub_resource type="Resource" id="Resource_pq7vv"]
script = ExtResource("1_akuff")
text = "[b]Quest & Inventory FSM[/b] — a self-driving quest engine (no input): an enum+match state machine walks OFFERED -> ACTIVE -> COMPLETE, a reused grant_item() function fills a Dictionary inventory + Array quest log and emits signals, and signal: triggers spring/tween the icon on every beat. Proves the sheet compiles real software logic — collections, signals, functions, match — not just movement."

[sub_resource type="Resource" id="Resource_aayxw"]
script = ExtResource("2_epfi1")
enum_name = "QuestState"
members = PackedStringArray("OFFERED", "ACTIVE", "COMPLETE")

[sub_resource type="Resource" id="Resource_rfbge"]
script = ExtResource("3_rc5qo")
signal_name = "item_collected"
params = PackedStringArray("id: String")

[sub_resource type="Resource" id="Resource_gp27s"]
script = ExtResource("3_rc5qo")
signal_name = "quest_advanced"
params = PackedStringArray("phase: int")

