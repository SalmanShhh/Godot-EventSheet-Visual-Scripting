[sub_resource type="Resource" id="Resource_y87b2"]
script = ExtResource("1_d3vt6")
text = "[b]Swarm[/b] — frame-spreading made visible. On Ready spawns 800 sprites into the \"swarm\" group; ONE For Each with a frame-spread budget of 90/frame wobbles them, so only a slice updates each frame and the colour refresh SWEEPS through the crowd — that visible wave IS the spreading. The FPS stays pinned even though the loop never touches the whole crowd in a single frame. Tick frame_spread_count on any For Each to get this — no behavior, no await."

[sub_resource type="Resource" id="Resource_aeoa0"]
script = ExtResource("6_l1bx6")
ace_id = "SetLocalVarTyped"
params = {
"name": "__cols",
"value": "40",
"var_type": "int"
}

[sub_resource type="Resource" id="Resource_2xjdq"]
script = ExtResource("5_meg26")
actions = Array[Resource]([SubResource("Resource_aeoa0")])
event_uid = "924de5"

[sub_resource type="Resource" id="Resource_gyuot"]
script = ExtResource("6_l1bx6")
ace_id = "SetLocalVarTyped"
params = {
"name": "__dot",
"value": "load(\"res://demo/showcase/dot.tscn\").instantiate()",
"var_type": "Sprite2D"
}

[sub_resource type="Resource" id="Resource_0p1qc"]
script = ExtResource("6_l1bx6")
ace_id = "SetPosition2D"
params = {
"pos": "Vector2(48.0 + float(__i % __cols) * 27.0, 70.0 + float(__i / __cols) * 27.0)",
"target": "__dot"
}

[sub_resource type="Resource" id="Resource_jrn30"]
script = ExtResource("6_l1bx6")
ace_id = "AddChild"
params = {
"node": "__dot"
}

[sub_resource type="Resource" id="Resource_h1s8m"]
script = ExtResource("4_r4gi0")
iterator_name = "__i: int"
collection_kind = 7
collection_value = "count"

[sub_resource type="Resource" id="Resource_7g88q"]
script = ExtResource("5_meg26")
actions = Array[Resource]([SubResource("Resource_gyuot"), SubResource("Resource_0p1qc"), SubResource("Resource_jrn30")])
event_uid = "b9858c"
pick_filters = Array[ExtResource("4_r4gi0")]([SubResource("Resource_h1s8m")])

[sub_resource type="Resource" id="Resource_ortmn"]
script = ExtResource("5_meg26")
trigger_provider_id = "Core"
trigger_id = "OnReady"
sub_events = Array[Resource]([SubResource("Resource_2xjdq"), SubResource("Resource_7g88q")])
event_uid = "d44ddb"

[sub_resource type="Resource" id="Resource_6c7hc"]
script = ExtResource("7_v6yy3")
code = "t += delta"

[sub_resource type="Resource" id="Resource_j2qth"]
script = ExtResource("6_l1bx6")
ace_id = "SetTextFormatted"
params = {
"args": "count, Engine.get_frames_per_second()",
"target": "$Info",
"template": "\"%d sprites   ·   Budgeted For Each: 90/frame   ·   %d FPS\""
}
codegen_template = "{target}.text = {template} % [{args}]"

[sub_resource type="Resource" id="Resource_hy1i6"]
script = ExtResource("5_meg26")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
