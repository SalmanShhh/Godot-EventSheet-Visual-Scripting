[sub_resource type="Resource" id="Resource_v6yy3"]
script = ExtResource("1_tt8hc")
text = "[b]Swarm[/b] — frame-spreading made visible. On Ready spawns 800 sprites into the \"swarm\" group; ONE For Each with a frame-spread budget of 90/frame wobbles them, so only a slice updates each frame and the colour refresh SWEEPS through the crowd — that visible wave IS the spreading. The FPS stays pinned even though the loop never touches the whole crowd in a single frame. Tick frame_spread_count on any For Each to get this — no behavior, no await."

[sub_resource type="Resource" id="Resource_tbpb0"]
script = ExtResource("2_d3vt6")
code = "var __cols: int = 40
for __i: int in range(count):
	var __dot: Sprite2D = load(\"res://demo/showcase/dot.tscn\").instantiate()
	__dot.position = Vector2(48.0 + float(__i % __cols) * 27.0, 70.0 + float(__i / __cols) * 27.0)
	add_child(__dot)"

[sub_resource type="Resource" id="Resource_y87b2"]
script = ExtResource("6_meg26")
trigger_provider_id = "Core"
trigger_id = "OnReady"
actions = Array[Resource]([SubResource("Resource_tbpb0")])
event_uid = "d44ddb"

[sub_resource type="Resource" id="Resource_aeoa0"]
script = ExtResource("2_d3vt6")
code = "t += delta"

[sub_resource type="Resource" id="Resource_2xjdq"]
script = ExtResource("2_d3vt6")
code = "$Info.text = \"%d sprites   ·   Budgeted For Each: 90/frame   ·   %d FPS\" % [count, Engine.get_frames_per_second()]"

[sub_resource type="Resource" id="Resource_gyuot"]
script = ExtResource("6_meg26")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
actions = Array[Resource]([SubResource("Resource_aeoa0"), SubResource("Resource_2xjdq")])
