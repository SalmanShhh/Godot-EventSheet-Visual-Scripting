[sub_resource type="Resource" id="Resource_s4y80"]
script = ExtResource("4_r4gi0")
iterator_name = "dot"
collection_kind = 0
collection_value = "swarm"
frame_spread_count = 90

[sub_resource type="Resource" id="Resource_6uurd"]
script = ExtResource("6_l1bx6")
ace_id = "SetCameraOffset"
params = {
"offset": "Vector2(sin(t * 2.0 + dot.position.x * 0.02) * 10.0, cos(t * 2.4 + dot.position.y * 0.02) * 10.0)",
"target": "dot"
}

[sub_resource type="Resource" id="Resource_wxg3f"]
script = ExtResource("6_l1bx6")
ace_id = "SetModulate"
params = {
"color": "Color.from_hsv(fmod(t * 0.08 + dot.position.x * 0.0008, 1.0), 0.65, 1.0)",
"target": "dot"
}

[sub_resource type="Resource" id="Resource_o20wf"]
