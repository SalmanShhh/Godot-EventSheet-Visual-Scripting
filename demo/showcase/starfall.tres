[sub_resource type="Resource" id="Resource_133ru"]
script = ExtResource("1_sb5am")
text = "[b]Starfall[/b] — a complete restartable arcade game authored as events: move the ship (ui_left/ui_right) to catch falling stars. Shows an enum+match state machine (PLAYING/GAME_OVER), a group pick-filter that scores & culls stars, an Every-2s spawner, and if/elif input branches. Miss 3 and it's GAME OVER — press ui_accept to restart."

[sub_resource type="Resource" id="Resource_my76c"]
script = ExtResource("2_ljl3c")
members = PackedStringArray("PLAYING", "GAME_OVER")

[sub_resource type="Resource" id="Resource_yej23"]
script = ExtResource("3_78k8l")
ace_id = "SetProperty"
params = {
"property": "position",
"target": "$Ship",
"value": "Vector2(576, 590)"
}
codegen_template = "{target}.{property} = {value}"

[sub_resource type="Resource" id="Resource_tf8x0"]
script = ExtResource("7_85q7n")
trigger_provider_id = "Core"
trigger_id = "OnReady"
actions = Array[Resource]([SubResource("Resource_yej23")])
event_uid = "dc02fd"

[sub_resource type="Resource" id="Resource_lp6og"]
script = ExtResource("8_728t8")
branches_text = "State.PLAYING:
	pass
State.GAME_OVER:
	if Input.is_action_just_pressed(&\"ui_accept\"):
		score = 0
		lives = 3
		state = State.PLAYING
		for s: Node in get_tree().get_nodes_in_group(\"stars\"):
			s.queue_free()
_:
	pass"

