[sub_resource type="Resource" id="Resource_xvmcs"]
script = ExtResource("4_5edww")
ace_id = "EveryXSeconds"
params = {
"seconds": "2.0"
}
codegen_template = "__every_spawn_sf >= maxf(2.0, 0.001)"
member_declaration = "var __every_spawn_sf: float = 0.0"
codegen_prelude = "__every_spawn_sf += delta"
codegen_on_true = "__every_spawn_sf = fmod(__every_spawn_sf, maxf(2.0, 0.001))"

