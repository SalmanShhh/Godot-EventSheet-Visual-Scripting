[sub_resource type="Resource" id="Resource_o44ja"]
script = ExtResource("9_133ru")
ace_id = "SpawnSceneAt"
codegen_template = "var __spawn_star = load(\"res://demo/showcase/star.tscn\").instantiate()
__spawn_star.position = Vector2(randf_range(60.0, 1100.0), -20.0)
__spawn_star.rotation_degrees = 90.0
add_child(__spawn_star)"

