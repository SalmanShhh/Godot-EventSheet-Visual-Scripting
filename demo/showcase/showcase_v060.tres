[sub_resource type="Resource" id="Resource_xx0ug"]
script = ExtResource("1_75ww0")
text = "[b]v0.6.0 showcase[/b] — a runtime-toggleable [i]Juice[/i] group pulses the host every 2s through the Spring behavior while Tween spins it. Run with Live Values on: watch [b]pulses[/b] climb, double-click to rewrite it live, and flip the group off with Set Group Active."

[sub_resource type="Resource" id="Resource_njfw3"]
script = ExtResource("2_pu8qr")
code = "pulses += 1
$SpringBehavior.set_spring(\"__scale\", 1.0)
$SpringBehavior.spring_host_scale(1.0)
$SpringBehavior.add_impulse(\"__scale\", pulse_scale * 4.0)
$TweenBehavior.tween_rotation(rotation_degrees + 90.0, 0.6)"

[sub_resource type="Resource" id="Resource_0l2nu"]
script = ExtResource("3_lu21b")
ace_id = "EveryXSeconds"
params = {
"seconds": "2.0"
}
codegen_template = "__every_5c0wca5e >= maxf(2.0, 0.001)"
member_declaration = "var __every_5c0wca5e: float = 0.0"
codegen_prelude = "__every_5c0wca5e += delta"
codegen_on_true = "__every_5c0wca5e = fmod(__every_5c0wca5e, maxf(2.0, 0.001))"

[sub_resource type="Resource" id="Resource_q2j2t"]
script = ExtResource("6_0de0g")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
conditions = Array[ExtResource("3_lu21b")]([SubResource("Resource_0l2nu")])
actions = Array[Resource]([SubResource("Resource_njfw3")])
event_uid = "5d7fd6"

[sub_resource type="Resource" id="Resource_ju2ix"]
script = ExtResource("7_hxqg4")
group_name = "Juice"
events = Array[Resource]([SubResource("Resource_q2j2t")])
group_uid = "fd5f28"
custom_color = Color(0.55, 0.4, 0.85, 1)
runtime_toggleable = true

[resource]
script = ExtResource("8_4gymm")
host_class = "Node2D"
emit_live_values = true
custom_class_name = "ShowcaseV060"
addon_tags = PackedStringArray()
events = Array[Resource]([SubResource("Resource_xx0ug"), SubResource("Resource_ju2ix")])
variables = {
"pulse_scale": {
"attributes": {
"clamp": true,
"range": {
"max": "3",
"min": "1",
"step": "0.05"
},
"tooltip": "How hard the spring kicks."
},
"default": 1.35,
"exported": true,
"type": "float"
},
"pulses": {
"attributes": {
"range": {
"max": "999",
"min": "0",
"step": "1"
},
"tooltip": "How many juice pulses have fired (watch it in Live Values — and edit it!)."
},
"default": 0,
"exported": true,
"type": "int"
}
}
