; Engine configuration file.
; It's best edited using the editor and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]
config/name="EventForge Demo"
run/main_scene="res://scenes/player.tscn"

[autoload]
EventForgeBridge="*res://../addons/eventforge/runtime/eventforge_bridge.gd"

[editor_plugins]
enabled=PackedStringArray("res://../addons/eventforge/plugin.cfg")
