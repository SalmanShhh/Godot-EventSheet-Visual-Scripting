[sub_resource type="Resource" id="Resource_nor7m"]
script = ExtResource("2_jstna")
code = "if ignoring_input or host == null:
	return
var dt: float = get_physics_process_delta_time()
var new_pos := Vector2(target_x, target_y)
if dt > 0.0:
	report_vel = (new_pos - host.global_position) / dt
host.global_position = new_pos
vel = Vector2.ZERO"

