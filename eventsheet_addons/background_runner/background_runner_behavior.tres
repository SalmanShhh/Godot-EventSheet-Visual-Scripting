[sub_resource type="Resource" id="Resource_6a3t0"]
script = ExtResource("10_00515")
function_name = "run_in_background"
description = "Runs a PURE callable off the main thread; On Done(result) fires when it finishes. WARNING: the callable must NOT touch nodes / the scene tree / non-thread-safe resources — data in, data out only."
expose_as_ace = true
ace_display_name = "Run In Background"
ace_category = "Background"
params = Array[ExtResource("9_rwyty")]([SubResource("Resource_afwb6")])
events = Array[Resource]([SubResource("Resource_el557"), SubResource("Resource_ltvdf")])

