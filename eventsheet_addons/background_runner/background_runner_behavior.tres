[sub_resource type="Resource" id="Resource_owgv0"]
script = ExtResource("8_84l1n")
function_name = "run_in_background"
description = "Runs a PURE callable off the main thread; On Done(result) fires when it finishes. WARNING: the callable must NOT touch nodes / the scene tree / non-thread-safe resources — data in, data out only."
expose_as_ace = true
ace_display_name = "Run In Background"
ace_category = "Background"
params = Array[ExtResource("7_uugj5")]([SubResource("Resource_axfwi")])
events = Array[Resource]([SubResource("Resource_dx17e")])

[sub_resource type="Resource" id="Resource_e0cyr"]
script = ExtResource("2_jeyil")
code = "for __item: Variant in items:
	run_in_background(work.bind(__item))"

