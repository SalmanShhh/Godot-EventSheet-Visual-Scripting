[sub_resource type="Resource" id="Resource_dkcia"]
script = ExtResource("1_wi416")
text = "Run In Background: hands a PURE function (no scene-tree access!) to a worker thread; On Done(result) fires on the main thread when it finishes. For heavy compute that would hitch even when spread across frames."

[sub_resource type="Resource" id="Resource_rwyty"]
script = ExtResource("2_jeyil")
code = "# In-flight tasks as [task_id, call_id]; results keyed by call_id, written off-thread under _mutex.
var _tasks: Array = []
var _results: Dictionary = {}
var _next_id: int = 0
var _mutex: Mutex = null

## @ace_trigger
## @ace_name(\"On Done\")
## @ace_category(\"Background\")
signal done(result: Variant)

## @ace_condition
## @ace_name(\"Is Running\")
## @ace_category(\"Background\")
## @ace_codegen_template(\"$BackgroundRunner.is_running()\")
func is_running() -> bool:
	return not _tasks.is_empty()

## @ace_expression
## @ace_name(\"Tasks Running\")
## @ace_category(\"Background\")
func tasks_running() -> int:
	return _tasks.size()

## Runs the (PURE) work callable off the main thread, then stores its result for the poll to emit.
func _run_task(work: Callable, call_id: int) -> void:
	var result: Variant = work.call()
	_mutex.lock()
	_results[call_id] = result
	_mutex.unlock()"

[sub_resource type="Resource" id="Resource_00515"]
script = ExtResource("2_jeyil")
code = "_mutex = Mutex.new()"

[sub_resource type="Resource" id="Resource_x2pyo"]
script = ExtResource("6_xpw5m")
trigger_provider_id = "Core"
trigger_id = "OnReady"
actions = Array[Resource]([SubResource("Resource_00515")])
event_uid = "97175f"

[sub_resource type="Resource" id="Resource_7q1e1"]
script = ExtResource("2_jeyil")
code = "if _tasks.is_empty():
	return
for __i: int in range(_tasks.size() - 1, -1, -1):
	var __entry: Array = _tasks[__i]
	if WorkerThreadPool.is_task_completed(__entry[0]):
		WorkerThreadPool.wait_for_task_completion(__entry[0])
		_mutex.lock()
		var __result: Variant = _results.get(__entry[1], null)
		_results.erase(__entry[1])
		_mutex.unlock()
		_tasks.remove_at(__i)
		done.emit(__result)"

[sub_resource type="Resource" id="Resource_k4g2r"]
script = ExtResource("6_xpw5m")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
actions = Array[Resource]([SubResource("Resource_7q1e1")])
event_uid = "abf11a"

[sub_resource type="Resource" id="Resource_dx17e"]
script = ExtResource("2_jeyil")
code = "if _mutex == null:
	_mutex = Mutex.new()
var __cid: int = _next_id
_next_id += 1
var __tid: int = WorkerThreadPool.add_task(_run_task.bind(work, __cid))
_tasks.append([__tid, __cid])"

