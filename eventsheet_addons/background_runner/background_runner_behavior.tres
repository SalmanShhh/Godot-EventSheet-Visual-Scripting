script = ExtResource("9_dkcia")
function_name = "run_in_background"
description = "Runs a PURE callable off the main thread; On Done(result) fires when it finishes. WARNING: the callable must NOT touch nodes / the scene tree / non-thread-safe resources — data in, data out only."
