[sub_resource type="Resource" id="Resource_7q1e1"]
script = ExtResource("1_ph2uq")
text = "Run In Background: hands a PURE function (no scene-tree access!) to a worker thread; On Done(result) fires on the main thread when it finishes. For heavy compute that would hitch even when spread across frames."

[sub_resource type="Resource" id="Resource_k4g2r"]
script = ExtResource("2_7ggxn")
signal_name = "done"
params = PackedStringArray("result: Variant")
trigger = true
ace_name = "On Done"
ace_category = "Background"

[sub_resource type="Resource" id="Resource_dx17e"]
script = ExtResource("3_c5cjv")
code = "# In-flight tasks as [task_id, call_id]; results keyed by call_id, written off-thread under _mutex.
var _tasks: Array = []
var _results: Dictionary = {}
var _next_id: int = 0
var _mutex: Mutex = null"

[sub_resource type="Resource" id="Resource_axfwi"]
script = ExtResource("8_dkcia")
ace_id = "SetVar"
params = {
"value": "Mutex.new()",
"var_name": "_mutex"
}

