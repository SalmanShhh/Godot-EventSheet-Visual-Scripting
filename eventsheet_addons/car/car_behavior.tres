[ext_resource type="Script" path="res://addons/eventforge/resources/signal_row.gd" id="2_ct0p5"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_condition.gd" id="3_saqex"]
[ext_resource type="Script" path="res://addons/eventforge/resources/local_variable.gd" id="4_8vblq"]
[ext_resource type="Script" path="res://addons/eventforge/resources/pick_filter.gd" id="5_bgk0m"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_row.gd" id="6_s1mgl"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_action.gd" id="7_1hj83"]
[ext_resource type="Script" path="res://addons/eventforge/resources/raw_code_row.gd" id="8_1707f"]
