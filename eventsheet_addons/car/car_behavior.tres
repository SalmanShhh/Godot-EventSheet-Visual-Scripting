"exported": true,
"type": "float"
},
"deceleration": {
"default": 400.0,
"exported": true,
"type": "float"
},
"drift_angle_threshold": {
"default": 15.0,
"exported": true,
"type": "float"
},
"drift_recover": {
"default": 0.15,
"exported": true,
"type": "float"
},
"max_speed": {
"default": 400.0,
"exported": true,
"type": "float"
},
"speed": {
"default": 0.0,
"exported": false,
"type": "float"
},
"steer_degrees": {
"default": 180.0,
"exported": true,
"type": "float"
},
"turn_while_stopped": {
"default": false,
"exported": true,
"type": "bool"
}
}
functions = Array[Resource]([SubResource("Resource_o4167")])
