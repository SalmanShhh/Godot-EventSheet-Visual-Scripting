[resource]
script = ExtResource("11_8htxg")
host_class = "CharacterBody2D"
behavior_mode = true
custom_class_name = "CarBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_3ywck"), SubResource("Resource_66i7s"), SubResource("Resource_88562"), SubResource("Resource_6osp1")])
variables = {
"_drifting": {
"default": false,
"exported": false,
"type": "bool"
},
"acceleration": {
"default": 300.0,
"exported": true,
"type": "float"
},
"deceleration": {
"default": 400.0,
"exported": true,
"type": "float"
},
"drift_angle_threshold": {
"default": 15.0,
"exported": true,
"type": "float"
},
"drift_recover": {
"default": 0.15,
"exported": true,
"type": "float"
},
"max_speed": {
"default": 400.0,
"exported": true,
"type": "float"
},
"speed": {
"default": 0.0,
"exported": false,
"type": "float"
},
"steer_degrees": {
"default": 180.0,
"exported": true,
"type": "float"
},
"turn_while_stopped": {
"default": false,
"exported": true,
"type": "bool"
}
}
functions = Array[Resource]([SubResource("Resource_de6mh")])
