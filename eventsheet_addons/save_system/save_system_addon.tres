[resource]
script = ExtResource("11_h03nn")
autoload_mode = true
autoload_name = "SaveSystem"
custom_class_name = "SaveSystemAddon"
addon_tags = PackedStringArray("persistence")
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_fvwqe"), SubResource("Resource_3ud0f"), SubResource("Resource_3fyie"), SubResource("Resource_xwtfp"), SubResource("Resource_xjiya")])
variables = {
"autosave_accumulator": {
"default": 0.0,
"exported": false,
"type": "float"
},
"autosave_interval": {
"attributes": {
"range": {
"max": "600",
"min": "0",
"step": "1"
},
"tooltip": "Seconds between autosaves (0 = off). Fires On Before Save first."
},
"default": 0.0,
"exported": true,
"type": "float"
},
"encryption_key": {
"attributes": {
"tooltip": "Non-empty = encrypted saves (keep the key out of screenshots!)."
},
"default": "",
"exported": true,
"type": "String"
},
"file_pattern": {
"attributes": {
"tooltip": "{slot} becomes the slot number."
},
"default": "save_{slot}.cfg",
"exported": true,
"type": "String"
},
"format": {
"default": "config",
"exported": true,
"options": ["config", "json"],
"type": "String"
},
"save_directory": {
"attributes": {
"tooltip": "Where save files live."
},
"default": "user://",
"exported": true,
"type": "String"
},
"section": {
"attributes": {
"tooltip": "ConfigFile section / JSON namespace for values."
},
"default": "save",
"exported": true,
"type": "String"
},
"slot": {
"attributes": {
"group": "Save System",
"range": {
"max": "9",
"min": "0",
"step": "1"
},
"tooltip": "Active save slot (each slot is its own file)."
},
"default": 0,
"exported": true,
"type": "int"
}
}
functions = Array[Resource]([SubResource("Resource_sg1v5"), SubResource("Resource_n48t7"), SubResource("Resource_owu2g"), SubResource("Resource_74vb5"), SubResource("Resource_lt2lm"), SubResource("Resource_yn3fb"), SubResource("Resource_oumhr"), SubResource("Resource_d8qtl"), SubResource("Resource_m1y65"), SubResource("Resource_vnouc"), SubResource("Resource_jnxqm"), SubResource("Resource_m5sia"), SubResource("Resource_pr1nd"), SubResource("Resource_3g0pq"), SubResource("Resource_ksu16"), SubResource("Resource_2ffiy")])
