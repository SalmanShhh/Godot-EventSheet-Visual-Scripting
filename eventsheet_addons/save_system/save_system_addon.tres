[resource]
script = ExtResource("9_flxs2")
autoload_mode = true
autoload_name = "SaveSystem"
custom_class_name = "SaveSystemAddon"
addon_tags = PackedStringArray("persistence")
events = Array[Resource]([SubResource("Resource_n23dw"), SubResource("Resource_amh6u"), SubResource("Resource_h03nn")])
variables = {
"autosave_accumulator": {
"default": 0.0,
"exported": false,
"type": "float"
},
"autosave_interval": {
"attributes": {
"range": {
"max": "600",
"min": "0",
"step": "1"
},
"tooltip": "Seconds between autosaves (0 = off). Fires On Before Save first."
},
"default": 0.0,
"exported": true,
"type": "float"
},
"encryption_key": {
"attributes": {
"tooltip": "Non-empty = encrypted saves (keep the key out of screenshots!)."
},
"default": "",
"exported": true,
"type": "String"
},
"file_pattern": {
"attributes": {
"tooltip": "{slot} becomes the slot number."
},
"default": "save_{slot}.cfg",
"exported": true,
"type": "String"
},
"format": {
"default": "config",
"exported": true,
"options": ["config", "json"],
"type": "String"
},
"save_directory": {
"attributes": {
"tooltip": "Where save files live."
},
"default": "user://",
"exported": true,
"type": "String"
},
"section": {
"attributes": {
"tooltip": "ConfigFile section / JSON namespace for values."
},
"default": "save",
"exported": true,
"type": "String"
},
"slot": {
"attributes": {
"group": "Save System",
"range": {
"max": "9",
"min": "0",
"step": "1"
},
"tooltip": "Active save slot (each slot is its own file)."
},
"default": 0,
"exported": true,
"type": "int"
}
}
functions = Array[Resource]([SubResource("Resource_xwtfp"), SubResource("Resource_6a8sv"), SubResource("Resource_fu0d4"), SubResource("Resource_yrdlv"), SubResource("Resource_14fj2"), SubResource("Resource_0fywq"), SubResource("Resource_8610w"), SubResource("Resource_ng3xc"), SubResource("Resource_1bnkf"), SubResource("Resource_owu2g"), SubResource("Resource_pqew2"), SubResource("Resource_lxiv3"), SubResource("Resource_qmk5k")])
