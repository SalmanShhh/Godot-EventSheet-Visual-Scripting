[resource]
script = ExtResource("11_h03nn")
autoload_mode = true
autoload_name = "SaveSystem"
custom_class_name = "SaveSystemAddon"
addon_tags = PackedStringArray("persistence")
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_fvwqe"), SubResource("Resource_3ud0f"), SubResource("Resource_3fyie"), SubResource("Resource_xwtfp"), SubResource("Resource_e0wex"), SubResource("Resource_yrdlv")])
variables = {
"autosave_accumulator": {
"default": 0.0,
"exported": false,
"type": "float"
},
"autosave_interval": {
"attributes": {
"range": {
"max": "600",
"min": "0",
"step": "1"
},
"tooltip": "Seconds between autosaves (0 = off). Fires On Before Save first."
},
"default": 0.0,
"exported": true,
"type": "float"
},
"encryption_key": {
"attributes": {
"tooltip": "Non-empty = encrypted saves (keep the key out of screenshots!)."
},
"default": "",
"exported": true,
"type": "String"
},
"file_pattern": {
"attributes": {
"tooltip": "{slot} becomes the slot number."
},
"default": "save_{slot}.cfg",
"exported": true,
"type": "String"
},
"format": {
"default": "config",
"exported": true,
"options": ["config", "json"],
"type": "String"
},
"save_directory": {
"attributes": {
"tooltip": "Where save files live."
},
"default": "user://",
"exported": true,
"type": "String"
},
