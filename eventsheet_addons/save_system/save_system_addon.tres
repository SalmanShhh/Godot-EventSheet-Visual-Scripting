[sub_resource type="Resource" id="Resource_74vb5"]
script = ExtResource("2_w5kqx")
code = "var found: Array = []
for candidate: int in range(100):
	if FileAccess.file_exists(_slot_path(candidate)):
		found.append(candidate)
return found"

