[sub_resource type="Resource" id="Resource_vdsu5"]
script = ExtResource("2_7bl26")
code = "plan = _decompose(root_task, 0)
plan_index = 0
if plan.is_empty():
	plan_failed.emit()
else:
	task_started.emit(str(plan[0]))"

[sub_resource type="Resource" id="Resource_ux87y"]
script = ExtResource("4_njcsg")
function_name = "request_plan"
description = "Decomposes the root task into a plan and starts the first task."
expose_as_ace = true
ace_display_name = "Request Plan"
ace_category = "HTN"
events = Array[Resource]([SubResource("Resource_vdsu5")])

[sub_resource type="Resource" id="Resource_5kdvo"]
script = ExtResource("2_7bl26")
code = "if plan_index >= plan.size():
	return
plan_index += 1
if plan_index >= plan.size():
	plan = []
	plan_index = 0
	plan_complete.emit()
else:
	task_started.emit(str(plan[plan_index]))"

[sub_resource type="Resource" id="Resource_617yk"]
script = ExtResource("4_njcsg")
function_name = "mark_complete"
description = "Advances to the next task, or fires On Plan Complete at the end."
expose_as_ace = true
ace_display_name = "Mark Task Complete"
ace_category = "HTN"
events = Array[Resource]([SubResource("Resource_5kdvo")])

[sub_resource type="Resource" id="Resource_s8cxo"]
script = ExtResource("2_7bl26")
code = "if auto_replan_on_fail:
	request_plan()
else:
	plan = []
	plan_index = 0
	plan_failed.emit()"

[sub_resource type="Resource" id="Resource_6rxx7"]
script = ExtResource("4_njcsg")
function_name = "mark_failed"
description = "Re-plans from the root (or fires On Plan Failed if auto-replan is off)."
expose_as_ace = true
ace_display_name = "Mark Task Failed"
ace_category = "HTN"
events = Array[Resource]([SubResource("Resource_s8cxo")])

[sub_resource type="Resource" id="Resource_5ieev"]
script = ExtResource("2_7bl26")
code = "plan = []
plan_index = 0"

[sub_resource type="Resource" id="Resource_n4cpw"]
script = ExtResource("4_njcsg")
function_name = "invalidate_plan"
