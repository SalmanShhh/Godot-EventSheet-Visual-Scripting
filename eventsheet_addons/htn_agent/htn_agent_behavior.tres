[sub_resource type="Resource" id="Resource_870ed"]
script = ExtResource("2_7bl26")
code = "if not compounds.has(task_name):
	compounds[task_name] = []
var method: HTNMethod = _find_method(task_name, method_id)
if method == null:
	var m: HTNMethod = HTNMethod.new()
	m.id = method_id
	m.utility = utility
	compounds[task_name].append(m)
else:
	method.utility = utility"

