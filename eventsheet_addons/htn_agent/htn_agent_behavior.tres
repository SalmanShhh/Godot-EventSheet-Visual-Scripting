trigger = true
ace_name = "On Plan Failed"
ace_category = "HTN"

[sub_resource type="Resource" id="Resource_qgett"]
script = ExtResource("3_2sslc")
code = "## An HTN method — a way to accomplish a compound task, with preconditions + an ordered subtask list.
class HTNMethod:
	var id: String = \"\"
	var utility: float = 0.0
	var conditions: Array = []
	var subtasks: Array = []

## A precondition (world-state key, operator, expected value) a method needs to be chosen.
class HTNCondition:
	var key: String = \"\"
	var op: String = \"==\"
	var value: Variant = null
# ── Planner internals ──
func _find_method(task_name: String, method_id: String) -> HTNMethod:
	for method: HTNMethod in compounds.get(task_name, []):
		if method.id == method_id:
			return method
	return null"

