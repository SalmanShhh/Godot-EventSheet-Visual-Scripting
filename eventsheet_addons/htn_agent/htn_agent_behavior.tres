ace_category = "HTN"
events = Array[Resource]([SubResource("Resource_5ieev")])

[resource]
script = ExtResource("5_aigr4")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "HTNAgent"
addon_tags = PackedStringArray("ai", "planning")
events = Array[Resource]([SubResource("Resource_q5b8g"), SubResource("Resource_loqp0")])
variables = {
"auto_replan_on_fail": {
"attributes": {
"tooltip": "Mark Failed re-plans from the root instead of giving up."
},
"default": true,
"exported": true,
"type": "bool"
},
"compounds": {
"default": {},
"exported": false,
"type": "Dictionary"
},
"plan": {
"default": [],
"exported": false,
"type": "Array"
},
"plan_index": {
"default": 0,
"exported": false,
"type": "int"
},
"primitives": {
"default": {},
"exported": false,
"type": "Dictionary"
},
"root_task": {
"attributes": {
"tooltip": "Goal to plan for — a compound or primitive task name."
},
"default": "",
"exported": true,
"type": "String"
},
"world_state": {
"default": {},
"exported": false,
"type": "Dictionary"
}
}
functions = Array[Resource]([SubResource("Resource_1iywo"), SubResource("Resource_obmvm"), SubResource("Resource_6kwa2"), SubResource("Resource_ei1jl"), SubResource("Resource_t0ymc"), SubResource("Resource_s2r8e"), SubResource("Resource_vtrvb"), SubResource("Resource_hdh3k"), SubResource("Resource_13wyb"), SubResource("Resource_ux87y"), SubResource("Resource_617yk"), SubResource("Resource_6rxx7"), SubResource("Resource_n4cpw")])
