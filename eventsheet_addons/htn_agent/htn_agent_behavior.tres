[sub_resource type="Resource" id="Resource_6drcv"]
script = ExtResource("1_loqp0")
text = "Utility-driven HTN planner. In On Ready build a task network (Add Primitive / Add Compound / Add Method / Add Method Condition / Add Method Subtask) and set the Root Task. Feed facts with Set World State, call Request Plan, run the Current Task in your sheet, and call Mark Complete / Mark Failed. Highest-utility applicable method wins at each compound (with backtracking). Triggers: On Task Started, On Plan Complete, On Plan Failed."

[sub_resource type="Resource" id="Resource_n0rjc"]
script = ExtResource("2_s8dy0")
signal_name = "task_started"
params = PackedStringArray("task_name: String")
trigger = true
ace_name = "On Task Started"
ace_category = "HTN"

