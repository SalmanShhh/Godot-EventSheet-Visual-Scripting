[resource]
script = ExtResource("10_o4pmk")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "SimpleHealthBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_exeo8"), SubResource("Resource_xmwhe"), SubResource("Resource_oglca"), SubResource("Resource_v4c4a")])
variables = {
"current_health": {
"default": 100.0,
"exported": false,
"type": "float"
},
"destroy_on_death": {
"attributes": {
"tooltip": "queue_free the host the moment health reaches 0 (after On Death fires)."
},
"default": false,
"exported": true,
"type": "bool"
},
"health_absorption_rate": {
"default": 1.0,
"exported": false,
"type": "float"
},
"health_pools": {
"default": {},
"exported": false,
"type": "Dictionary"
},
"invulnerable": {
"attributes": {
"tooltip": "Start invulnerable: takeDamage is a no-op while true."
},
"default": false,
"exported": true,
"type": "bool"
},
"is_dead_flag": {
"default": false,
"exported": false,
"type": "bool"
},
"last_damage": {
"default": 0.0,
"exported": false,
"type": "float"
},
"last_heal": {
"default": 0.0,
"exported": false,
"type": "float"
},
"last_pool_damage_absorbed": {
"default": 0.0,
"exported": false,
"type": "float"
},
"last_trigger_pool_type": {
"default": "",
"exported": false,
"type": "String"
},
"max_health": {
"attributes": {
"range": {
"max": "10000",
"min": "1",
"step": "1"
},
"tooltip": "Starting max HP; current_health initialises to this."
},
"default": 100.0,
"exported": true,
"type": "float"
}
}
functions = Array[Resource]([SubResource("Resource_pvtbx"), SubResource("Resource_tu7nc"), SubResource("Resource_p3h2n"), SubResource("Resource_il0k0"), SubResource("Resource_rkoro"), SubResource("Resource_0gpit"), SubResource("Resource_i7wwt"), SubResource("Resource_w28ye"), SubResource("Resource_ik5q0"), SubResource("Resource_qdrux"), SubResource("Resource_1xs7q"), SubResource("Resource_7e4tc"), SubResource("Resource_d414x"), SubResource("Resource_rp0w0"), SubResource("Resource_0bhoq"), SubResource("Resource_fciat")])
