[sub_resource type="Resource" id="Resource_viqvc"]
script = ExtResource("2_0d086")
code = "if health_pools.is_empty():
	return
var depleted: Array = []
for pool_name in _sorted_pool_keys():
	var pool: Dictionary = health_pools[pool_name]
	if float(pool.amount) > 0.0 and float(pool.decay_rate) > 0.0:
		pool.amount = maxf(0.0, float(pool.amount) - float(pool.decay_rate) * delta)
		if float(pool.amount) <= 0.0:
			depleted.append(pool_name)
for pool_name in depleted:
	last_trigger_pool_type = pool_name
	on_health_pool_depleted.emit()"

[sub_resource type="Resource" id="Resource_oglca"]
script = ExtResource("6_5qxg0")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
actions = Array[Resource]([SubResource("Resource_viqvc")])
event_uid = "7e4242"

[sub_resource type="Resource" id="Resource_4p37g"]
script = ExtResource("2_0d086")
code = "if amount <= 0.0 or invulnerable or is_dead_flag:
	return
var remaining: float = amount
for pool_name: String in _sorted_pool_keys():
	if remaining <= 0.0:
		break
	var pool: Dictionary = health_pools[pool_name]
	if float(pool.amount) <= 0.0:
		continue
	var absorption: float = float(pool.absorption_rate)
	var max_absorbable: float = (float(pool.amount) / absorption) if absorption > 0.0 else INF
	var absorbed: float = minf(remaining, max_absorbable)
	pool.amount = maxf(0.0, float(pool.amount) - absorbed * absorption)
	pool.last_absorbed = absorbed
	remaining -= absorbed
	last_trigger_pool_type = pool_name
	last_pool_damage_absorbed = absorbed
	on_health_pool_absorbed.emit()
	if float(pool.amount) <= 0.0:
		on_health_pool_depleted.emit()
if remaining <= 0.0:
	return
var real_damage: float = remaining * health_absorption_rate
last_damage = real_damage
current_health -= real_damage
if current_health <= 0.0:
	current_health = 0.0
	is_dead_flag = true
	on_death.emit()
	on_health_changed.emit()
	if destroy_on_death and host != null:
		host.call_deferred(\"queue_free\")
else:
	on_damaged.emit()
	on_health_changed.emit()"

