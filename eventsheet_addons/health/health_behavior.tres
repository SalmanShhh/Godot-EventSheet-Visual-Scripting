},
"health_pools": {
"default": {},
"exported": false,
"type": "Dictionary"
},
"invulnerable": {
"attributes": {
"tooltip": "Start invulnerable: takeDamage is a no-op while true."
},
"default": false,
"exported": true,
"type": "bool"
},
"is_dead_flag": {
"default": false,
"exported": false,
"type": "bool"
},
"last_damage": {
