[resource]
script = ExtResource("12_rp2y6")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "TweenBehavior"
addon_tags = PackedStringArray("motion", "juice")
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_6r4o1"), SubResource("Resource_ldndk"), SubResource("Resource_dapsx")])
variables = {
"default_duration": {
"attributes": {
"range": {
"max": "10",
"min": "0.01",
"step": "0.01"
},
"tooltip": "Seconds used when a tween call passes 0."
},
"default": 0.3,
"exported": true,
"type": "float"
},
"easing": {
"default": "out",
"exported": true,
"options": ["in", "out", "in_out", "out_in"],
"type": "String"
},
"transition": {
"default": "sine",
"exported": true,
"options": ["linear", "sine", "quad", "cubic", "quart", "quint", "expo", "circ", "elastic", "back", "bounce", "spring"],
"type": "String"
}
}
functions = Array[Resource]([SubResource("Resource_p8fn1"), SubResource("Resource_jdd5u"), SubResource("Resource_074cn"), SubResource("Resource_vdt5h"), SubResource("Resource_513ss"), SubResource("Resource_svvv4"), SubResource("Resource_5me6n"), SubResource("Resource_dvub8"), SubResource("Resource_lry5d"), SubResource("Resource_2o6dg")])
