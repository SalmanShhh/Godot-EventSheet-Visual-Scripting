[resource]
script = ExtResource("11_elexq")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "TweenBehavior"
addon_tags = PackedStringArray("motion", "juice")
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_5ubra"), SubResource("Resource_rp2y6"), SubResource("Resource_6r4o1")])
variables = {
"default_duration": {
"attributes": {
"range": {
"max": "10",
"min": "0.01",
"step": "0.01"
},
"tooltip": "Seconds used when a tween call passes 0."
},
"default": 0.3,
"exported": true,
"type": "float"
},
"easing": {
"default": "out",
"exported": true,
"options": ["in", "out", "in_out", "out_in"],
"type": "String"
},
"transition": {
"default": "sine",
"exported": true,
"options": ["linear", "sine", "quad", "cubic", "quart", "quint", "expo", "circ", "elastic", "back", "bounce", "spring"],
"type": "String"
}
}
functions = Array[Resource]([SubResource("Resource_mcso3"), SubResource("Resource_y6s4t"), SubResource("Resource_bjbwr"), SubResource("Resource_vdsra"), SubResource("Resource_8rg7p"), SubResource("Resource_sd481")])
