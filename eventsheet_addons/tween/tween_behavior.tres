[resource]
script = ExtResource("10_paonx")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "TweenBehavior"
addon_tags = PackedStringArray("motion", "juice")
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_bxuom"), SubResource("Resource_elexq")])
variables = {
"default_duration": {
"attributes": {
"range": {
"max": "10",
"min": "0.01",
"step": "0.01"
},
"tooltip": "Seconds used when a tween call passes 0."
},
"default": 0.3,
"exported": true,
"type": "float"
},
"easing": {
"default": "out",
"exported": true,
"options": ["in", "out", "in_out", "out_in"],
"type": "String"
},
"transition": {
"default": "sine",
"exported": true,
"options": ["linear", "sine", "quad", "cubic", "quart", "quint", "expo", "circ", "elastic", "back", "bounce", "spring"],
"type": "String"
}
}
functions = Array[Resource]([SubResource("Resource_bpmm2"), SubResource("Resource_4sn2j"), SubResource("Resource_jdd5u"), SubResource("Resource_074cn"), SubResource("Resource_vdt5h"), SubResource("Resource_513ss")])
