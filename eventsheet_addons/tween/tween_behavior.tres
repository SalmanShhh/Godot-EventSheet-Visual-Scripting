[resource]
script = ExtResource("5_r84we")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "TweenBehavior"
addon_tags = PackedStringArray("motion", "juice")
events = Array[Resource]([SubResource("Resource_gnvbk"), SubResource("Resource_hlhhl")])
variables = {
"default_duration": {
"attributes": {
"range": {
"max": "10",
"min": "0.01",
"step": "0.01"
},
"tooltip": "Seconds used when a tween call passes 0."
},
"default": 0.3,
"exported": true,
"type": "float"
},
"easing": {
"default": "out",
"exported": true,
"options": ["in", "out", "in_out", "out_in"],
"type": "String"
},
"transition": {
"default": "sine",
"exported": true,
"options": ["linear", "sine", "quad", "cubic", "quart", "quint", "expo", "circ", "elastic", "back", "bounce", "spring"],
"type": "String"
}
}
functions = Array[Resource]([SubResource("Resource_5v5yh"), SubResource("Resource_elexq"), SubResource("Resource_ldndk"), SubResource("Resource_q24d4"), SubResource("Resource_4sn2j"), SubResource("Resource_64u0s")])
