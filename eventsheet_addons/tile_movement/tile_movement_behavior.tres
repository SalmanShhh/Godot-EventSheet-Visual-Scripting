[sub_resource type="Resource" id="Resource_0b1ao"]
script = ExtResource("1_vgvrg")
text = "Tile Movement behavior (C3 parity): grid-locked stepping (arrow keys or Simulate Step); grid-space helpers convert between tiles and pixels. Fires On Step Finished per tile."

[sub_resource type="Resource" id="Resource_gl44j"]
script = ExtResource("2_8yhrj")
code = "## @ace_trigger
## @ace_name(\"On Step Finished\")
## @ace_category(\"Tile Movement\")
signal step_finished"

[sub_resource type="Resource" id="Resource_s6njm"]
script = ExtResource("2_8yhrj")
code = "## @ace_hidden
func to_grid(pixel: Vector2) -> Vector2i:
	return Vector2i(roundi(pixel.x / tile_size), roundi(pixel.y / tile_size))

## @ace_hidden
func from_grid(tile: Vector2i) -> Vector2:
	return Vector2(tile) * tile_size"

[sub_resource type="Resource" id="Resource_svak1"]
script = ExtResource("2_8yhrj")
code = "if host == null:
	return
if moving:
	progress += delta / move_time
	if progress >= 1.0:
		host.position = Vector2(to_x, to_y)
		moving = false
		step_finished.emit()
	else:
		host.position = Vector2(from_x, from_y).lerp(Vector2(to_x, to_y), progress)
	return
var step := Vector2(pending_x, pending_y)
pending_x = 0.0
pending_y = 0.0
if step == Vector2.ZERO and default_controls:
	step = Vector2(Input.get_axis(&\"ui_left\", &\"ui_right\"), Input.get_axis(&\"ui_up\", &\"ui_down\"))
if step.x != 0.0:
	step.y = 0.0
if step != Vector2.ZERO:
	from_x = host.position.x
	from_y = host.position.y
	to_x = from_x + signf(step.x) * tile_size
	to_y = from_y + signf(step.y) * tile_size
	progress = 0.0
	moving = true"

[sub_resource type="Resource" id="Resource_6dtgv"]
script = ExtResource("6_g35kp")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
actions = Array[Resource]([SubResource("Resource_svak1")])
event_uid = "0474b7"

[sub_resource type="Resource" id="Resource_joxbd"]
script = ExtResource("2_8yhrj")
code = "if direction == \"left\":
	pending_x = -1.0
elif direction == \"right\":
	pending_x = 1.0
elif direction == \"up\":
	pending_y = -1.0
elif direction == \"down\":
	pending_y = 1.0"

[sub_resource type="Resource" id="Resource_u0ahq"]
script = ExtResource("7_f5eri")
id = "direction"
initial_value = null
initialValue = null

[sub_resource type="Resource" id="Resource_bxm2s"]
script = ExtResource("8_g5l8f")
function_name = "simulate_step"
description = "Steps one tile in a direction: left, right, up or down (C3 simulate control)."
expose_as_ace = true
ace_display_name = "Simulate Step"
ace_category = "Tile Movement"
params = Array[ExtResource("7_f5eri")]([SubResource("Resource_u0ahq")])
events = Array[Resource]([SubResource("Resource_joxbd")])

[sub_resource type="Resource" id="Resource_n1dyx"]
script = ExtResource("2_8yhrj")
code = "if host != null:
	host.position = Vector2(tile_x, tile_y) * tile_size
moving = false"

