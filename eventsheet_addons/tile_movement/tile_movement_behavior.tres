[sub_resource type="Resource" id="Resource_0b1ao"]
script = ExtResource("1_vgvrg")
text = "Tile Movement behavior (C3-style): grid-locked stepping with the arrow keys; fires On Step Finished per tile."

[sub_resource type="Resource" id="Resource_gl44j"]
script = ExtResource("2_8yhrj")
code = "## @ace_trigger
## @ace_name(\"On Step Finished\")
## @ace_category(\"Tile Movement\")
signal step_finished"

[sub_resource type="Resource" id="Resource_s6njm"]
script = ExtResource("2_8yhrj")
code = "if host == null:
	return
if moving:
	progress += delta / move_time
	if progress >= 1.0:
		host.position = Vector2(to_x, to_y)
		moving = false
		step_finished.emit()
	else:
		host.position = Vector2(from_x, from_y).lerp(Vector2(to_x, to_y), progress)
	return
var step := Vector2(Input.get_axis(&\"ui_left\", &\"ui_right\"), Input.get_axis(&\"ui_up\", &\"ui_down\"))
if step.x != 0.0:
	step.y = 0.0
if step != Vector2.ZERO:
	from_x = host.position.x
	from_y = host.position.y
	to_x = from_x + signf(step.x) * tile_size
	to_y = from_y + signf(step.y) * tile_size
	progress = 0.0
	moving = true"

[sub_resource type="Resource" id="Resource_svak1"]
script = ExtResource("6_g35kp")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
actions = Array[Resource]([SubResource("Resource_s6njm")])
event_uid = "2336da"

[sub_resource type="Resource" id="Resource_6dtgv"]
script = ExtResource("2_8yhrj")
code = "if host != null:
	host.position = Vector2(tile_x, tile_y) * tile_size
moving = false"

[sub_resource type="Resource" id="Resource_joxbd"]
