[sub_resource type="Resource" id="Resource_rgwaf"]
script = ExtResource("8_cs8cc")
function_name = "set_orbit_center"
description = "Orbits around the given point from now on."
expose_as_ace = true
ace_display_name = "Set Orbit Center"
ace_category = "Orbit"
params = Array[ExtResource("7_q3dsn")]([SubResource("Resource_yofqy"), SubResource("Resource_io6o6")])
events = Array[Resource]([SubResource("Resource_7xjsu")])

