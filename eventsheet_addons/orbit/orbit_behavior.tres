[resource]
script = ExtResource("10_odtee")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "OrbitBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_u8wjc"), SubResource("Resource_bybd2")])
variables = {
"angle": {
"default": 0.0,
"exported": false,
"type": "float"
},
"center_captured": {
"default": false,
"exported": false,
"type": "bool"
},
"center_x": {
"default": 0.0,
"exported": false,
"type": "float"
},
"center_y": {
"default": 0.0,
"exported": false,
"type": "float"
},
"match_rotation": {
"default": false,
"exported": true,
"type": "bool"
},
"offset_angle_degrees": {
"default": 0.0,
"exported": true,
"type": "float"
},
"primary_radius": {
"default": 100.0,
"exported": true,
"type": "float"
},
"secondary_radius": {
"default": 0.0,
"exported": true,
"type": "float"
},
"speed_degrees": {
"default": 90.0,
"exported": true,
"type": "float"
},
"total_rotation": {
"default": 0.0,
"exported": false,
"type": "float"
}
}
functions = Array[Resource]([SubResource("Resource_x017x"), SubResource("Resource_xcpih"), SubResource("Resource_5ul0s")])
