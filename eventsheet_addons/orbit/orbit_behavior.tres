[gd_resource type="Resource" script_class="EventSheetResource" format=3]

[ext_resource type="Script" path="res://addons/eventforge/resources/comment_row.gd" id="1_lpx84"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_condition.gd" id="2_50eko"]
[ext_resource type="Script" path="res://addons/eventforge/resources/local_variable.gd" id="3_rpwnl"]
[ext_resource type="Script" path="res://addons/eventforge/resources/pick_filter.gd" id="4_81upg"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_row.gd" id="5_edhbl"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_action.gd" id="6_q3dsn"]
[ext_resource type="Script" path="res://addons/eventforge/resources/raw_code_row.gd" id="7_cs8cc"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_param.gd" id="8_mgc0e"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_function.gd" id="9_c3hde"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_sheet.gd" id="10_odtee"]

[sub_resource type="Resource" id="Resource_u8wjc"]
script = ExtResource("1_lpx84")
text = "Orbit behavior (C3 parity): circles or ellipses around a point. secondary_radius 0 = circle; offset_angle tilts the ellipse; match_rotation faces the travel direction."

[sub_resource type="Resource" id="Resource_7xjsu"]
script = ExtResource("6_q3dsn")
ace_id = "ReturnEarly"

[sub_resource type="Resource" id="Resource_yofqy"]
script = ExtResource("2_50eko")
ace_id = "CompareVar"
params = {
"op": "==",
"value": "null",
"var_name": "host"
}

[sub_resource type="Resource" id="Resource_io6o6"]
script = ExtResource("5_edhbl")
conditions = Array[ExtResource("2_50eko")]([SubResource("Resource_yofqy")])
actions = Array[Resource]([SubResource("Resource_7xjsu")])
event_uid = "9a0fda"

[sub_resource type="Resource" id="Resource_rgwaf"]
script = ExtResource("6_q3dsn")
ace_id = "SetVar"
params = {
"value": "host.position.x",
"var_name": "center_x"
}

[sub_resource type="Resource" id="Resource_ux2da"]
script = ExtResource("6_q3dsn")
ace_id = "SetVar"
params = {
"value": "host.position.y",
"var_name": "center_y"
}

[sub_resource type="Resource" id="Resource_er1va"]
script = ExtResource("6_q3dsn")
ace_id = "SetVar"
params = {
"value": "true",
"var_name": "center_captured"
}

[sub_resource type="Resource" id="Resource_ib20v"]
script = ExtResource("2_50eko")
ace_id = "ExpressionIsTrue"
params = {
"expr": "not center_captured"
}

[sub_resource type="Resource" id="Resource_5rthf"]
script = ExtResource("5_edhbl")
conditions = Array[ExtResource("2_50eko")]([SubResource("Resource_ib20v")])
actions = Array[Resource]([SubResource("Resource_rgwaf"), SubResource("Resource_ux2da"), SubResource("Resource_er1va")])
event_uid = "ee3d8e"

[sub_resource type="Resource" id="Resource_qm3rt"]
script = ExtResource("7_cs8cc")
code = "var step := deg_to_rad(speed_degrees) * delta"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_ldi7v"]
script = ExtResource("6_q3dsn")
ace_id = "AddVar"
params = {
"amount": "step",
"var_name": "angle"
}

[sub_resource type="Resource" id="Resource_xhkt4"]
script = ExtResource("6_q3dsn")
ace_id = "AddVar"
params = {
"amount": "absf(step)",
"var_name": "total_rotation"
}

[sub_resource type="Resource" id="Resource_b8tou"]
script = ExtResource("7_cs8cc")
code = "var radius_b := secondary_radius if secondary_radius > 0.0 else primary_radius"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_drq7s"]
script = ExtResource("6_q3dsn")
ace_id = "CallMethod"
params = {
"args": "deg_to_rad(offset_angle_degrees)",
"method": "rotated",
"target": "var local := Vector2(cos(angle) * primary_radius, sin(angle) * radius_b)"
}

[sub_resource type="Resource" id="Resource_ygp8q"]
script = ExtResource("7_cs8cc")
code = "var previous := host.position"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_x30uk"]
script = ExtResource("6_q3dsn")
ace_id = "SetPosition2D"
params = {
"pos": "Vector2(center_x, center_y) + local",
"target": "host"
}

[sub_resource type="Resource" id="Resource_voced"]
script = ExtResource("5_edhbl")
actions = Array[Resource]([SubResource("Resource_qm3rt"), SubResource("Resource_ldi7v"), SubResource("Resource_xhkt4"), SubResource("Resource_b8tou"), SubResource("Resource_drq7s"), SubResource("Resource_ygp8q"), SubResource("Resource_x30uk")])
event_uid = "543b2f"

[sub_resource type="Resource" id="Resource_flt6p"]
script = ExtResource("6_q3dsn")
ace_id = "SetProperty"
params = {
"property": "rotation",
"target": "host",
"value": "(host.position - previous).angle()"
}

[sub_resource type="Resource" id="Resource_gmqmd"]
script = ExtResource("2_50eko")
ace_id = "ExpressionIsTrue"
params = {
"expr": "match_rotation"
}

[sub_resource type="Resource" id="Resource_ihnn4"]
script = ExtResource("2_50eko")
ace_id = "CompareVar"
params = {
"op": "!=",
"value": "previous",
"var_name": "host.position"
}

[sub_resource type="Resource" id="Resource_yb3i8"]
script = ExtResource("5_edhbl")
conditions = Array[ExtResource("2_50eko")]([SubResource("Resource_gmqmd"), SubResource("Resource_ihnn4")])
actions = Array[Resource]([SubResource("Resource_flt6p")])
event_uid = "ba6df1"

[sub_resource type="Resource" id="Resource_bybd2"]
script = ExtResource("5_edhbl")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
sub_events = Array[Resource]([SubResource("Resource_io6o6"), SubResource("Resource_5rthf"), SubResource("Resource_voced"), SubResource("Resource_yb3i8")])
event_uid = "68b348"

[sub_resource type="Resource" id="Resource_41pbv"]
script = ExtResource("6_q3dsn")
ace_id = "SetVar"
params = {
"value": "x",
"var_name": "center_x"
}

[sub_resource type="Resource" id="Resource_r7gvh"]
script = ExtResource("6_q3dsn")
ace_id = "SetVar"
params = {
"value": "y",
"var_name": "center_y"
}

[sub_resource type="Resource" id="Resource_udisn"]
script = ExtResource("6_q3dsn")
ace_id = "SetVar"
params = {
"value": "true",
"var_name": "center_captured"
}

[sub_resource type="Resource" id="Resource_3je14"]
script = ExtResource("5_edhbl")
actions = Array[Resource]([SubResource("Resource_41pbv"), SubResource("Resource_r7gvh"), SubResource("Resource_udisn")])
event_uid = "57e222"

