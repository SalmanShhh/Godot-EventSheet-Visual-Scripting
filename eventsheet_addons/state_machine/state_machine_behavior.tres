[gd_resource type="Resource" script_class="EventSheetResource" format=3]

[ext_resource type="Script" path="res://addons/eventforge/resources/comment_row.gd" id="1_84wsg"]
[ext_resource type="Script" path="res://addons/eventforge/resources/signal_row.gd" id="2_u0a6h"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_action.gd" id="3_ae0f8"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_condition.gd" id="4_j2x8f"]
[ext_resource type="Script" path="res://addons/eventforge/resources/local_variable.gd" id="5_31hh8"]
[ext_resource type="Script" path="res://addons/eventforge/resources/pick_filter.gd" id="6_k22m1"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_row.gd" id="7_dvnxi"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_param.gd" id="8_pnovj"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_function.gd" id="9_hkk8u"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_sheet.gd" id="10_tns7c"]

[sub_resource type="Resource" id="Resource_uuu4y"]
script = ExtResource("1_84wsg")
text = "State machine behavior: Set State / Is In State from any sheet; On State Changed fires with (previous, next)."

[sub_resource type="Resource" id="Resource_8ogfh"]
script = ExtResource("2_u0a6h")
signal_name = "state_changed"
params = PackedStringArray("previous: String", "next: String")
trigger = true
ace_name = "On State Changed"
ace_category = "State Machine"

[sub_resource type="Resource" id="Resource_tsnbi"]
script = ExtResource("3_ae0f8")
ace_id = "ReturnValue"
params = {
"value": "state == state_name"
}

[sub_resource type="Resource" id="Resource_6pf0y"]
script = ExtResource("7_dvnxi")
actions = Array[Resource]([SubResource("Resource_tsnbi")])
event_uid = "177dcc"

[sub_resource type="Resource" id="Resource_kxy58"]
script = ExtResource("8_pnovj")
id = "state_name"
initial_value = null
initialValue = null

[sub_resource type="Resource" id="Resource_23tsv"]
script = ExtResource("9_hkk8u")
function_name = "is_in_state"
description = "True while the machine is in the given state."
expose_as_ace = true
ace_display_name = "Is In State"
ace_category = "State Machine"
params = Array[ExtResource("8_pnovj")]([SubResource("Resource_kxy58")])
return_type = 1
events = Array[Resource]([SubResource("Resource_6pf0y")])

[sub_resource type="Resource" id="Resource_odbwt"]
script = ExtResource("3_ae0f8")
ace_id = "SetLocalVarTyped"
params = {
"name": "previous",
"value": "state",
"var_type": "String"
}

[sub_resource type="Resource" id="Resource_2cn64"]
script = ExtResource("3_ae0f8")
ace_id = "SetVar"
params = {
"value": "next",
"var_name": "state"
}

[sub_resource type="Resource" id="Resource_8dngg"]
script = ExtResource("3_ae0f8")
ace_id = "EmitSignal"
params = {
"args": "previous, next",
"signal_name": "state_changed"
}

[sub_resource type="Resource" id="Resource_d564g"]
script = ExtResource("4_j2x8f")
ace_id = "ExpressionIsTrue"
params = {
"expr": "state != next"
}

[sub_resource type="Resource" id="Resource_w810k"]
script = ExtResource("7_dvnxi")
conditions = Array[ExtResource("4_j2x8f")]([SubResource("Resource_d564g")])
actions = Array[Resource]([SubResource("Resource_odbwt"), SubResource("Resource_2cn64"), SubResource("Resource_8dngg")])
event_uid = "f82985"

[sub_resource type="Resource" id="Resource_mgip6"]
script = ExtResource("8_pnovj")
id = "next"
initial_value = null
initialValue = null

[sub_resource type="Resource" id="Resource_4hmih"]
script = ExtResource("9_hkk8u")
function_name = "set_state"
description = "Switches to the given state and fires On State Changed."
expose_as_ace = true
ace_display_name = "Set State"
ace_category = "State Machine"
params = Array[ExtResource("8_pnovj")]([SubResource("Resource_mgip6")])
events = Array[Resource]([SubResource("Resource_w810k")])

[resource]
script = ExtResource("10_tns7c")
behavior_mode = true
custom_class_name = "StateMachineBehavior"
addon_tags = PackedStringArray()
events = Array[Resource]([SubResource("Resource_uuu4y"), SubResource("Resource_8ogfh")])
variables = {
"state": {
"default": "idle",
"exported": true,
"type": "String"
}
}
functions = Array[Resource]([SubResource("Resource_23tsv"), SubResource("Resource_4hmih")])
