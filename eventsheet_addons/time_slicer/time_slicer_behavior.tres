[resource]
script = ExtResource("11_tbyw6")
behavior_mode = true
custom_class_name = "TimeSlicerBehavior"
addon_tags = PackedStringArray("performance", "scheduling")
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_0pebw"), SubResource("Resource_ht2af"), SubResource("Resource_1jdua"), SubResource("Resource_ic3dq")])
variables = {
"_last_count": {
"default": 0,
"exported": false,
"type": "int"
},
"_paused": {
"default": false,
"exported": false,
"type": "bool"
},
"_queue": {
"default": [],
"exported": false,
"type": "Array"
},
"frame_budget_ms": {
"attributes": {
"range": {
"max": "16",
"min": "0.1",
"step": "0.1"
},
"tooltip": "Max milliseconds per frame spent draining the queue (used when Mode includes ms)."
},
"default": 4.0,
"exported": true,
"type": "float"
},
"max_items_per_frame": {
"attributes": {
"tooltip": "Hard cap on items processed per frame (used when Mode includes count)."
},
"default": 64,
"exported": true,
"type": "int"
},
"mode": {
"default": "both",
"exported": true,
"options": ["both", "ms", "count"],
"type": "String"
}
}
functions = Array[Resource]([SubResource("Resource_4elpe"), SubResource("Resource_amysj"), SubResource("Resource_banw8"), SubResource("Resource_nb3ee"), SubResource("Resource_c0ybl"), SubResource("Resource_mdaen"), SubResource("Resource_mjvge"), SubResource("Resource_rsmjx"), SubResource("Resource_fhvu5"), SubResource("Resource_jxisj")])
