"step": "0.1"
},
"tooltip": "Max milliseconds per frame spent draining the queue (used when Mode includes ms)."
},
"default": 4.0,
"exported": true,
"type": "float"
},
"max_items_per_frame": {
"attributes": {
"tooltip": "Hard cap on items processed per frame (used when Mode includes count)."
},
"default": 64,
"exported": true,
"type": "int"
},
"mode": {
