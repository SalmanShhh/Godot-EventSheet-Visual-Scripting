[sub_resource type="Resource" id="Resource_0pebw"]
script = ExtResource("1_ecg1s")
text = "Time Slicer: a managed work queue that drains within a per-frame ms / count budget. Enqueue items, react to On Process Item(item) — heavy work self-spreads across frames with no loop, no await, no hitch."

[sub_resource type="Resource" id="Resource_ht2af"]
script = ExtResource("2_xkkd0")
signal_name = "process_item"
params = PackedStringArray("item: Variant")
trigger = true
ace_name = "On Process Item"
ace_category = "Time Slicer"

[sub_resource type="Resource" id="Resource_1jdua"]
script = ExtResource("2_xkkd0")
signal_name = "drained"
params = PackedStringArray()
trigger = true
ace_name = "On Drained"
ace_category = "Time Slicer"

[sub_resource type="Resource" id="Resource_84hue"]
script = ExtResource("7_uikdf")
ace_id = "ReturnEarly"

[sub_resource type="Resource" id="Resource_sjsb6"]
script = ExtResource("3_q274n")
ace_id = "DictIsEmpty"
params = {
"var_name": "_paused or _queue"
}

[sub_resource type="Resource" id="Resource_vijfo"]
script = ExtResource("6_pc2pk")
conditions = Array[ExtResource("3_q274n")]([SubResource("Resource_sjsb6")])
actions = Array[Resource]([SubResource("Resource_84hue")])
event_uid = "bf2215"

[sub_resource type="Resource" id="Resource_ybc4u"]
script = ExtResource("8_geigq")
code = "# Wall-clock ms fence — the one budget primitive shared across the frame-spreading tools."
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_r45xq"]
script = ExtResource("7_uikdf")
ace_id = "CallMethod"
params = {
"args": ") + int(frame_budget_ms * 1000.0",
"method": "get_ticks_usec",
"target": "var __budget_end := Time"
}

[sub_resource type="Resource" id="Resource_q4syt"]
script = ExtResource("8_geigq")
code = "var __n := 0"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_e53cp"]
script = ExtResource("6_pc2pk")
actions = Array[Resource]([SubResource("Resource_ybc4u"), SubResource("Resource_r45xq"), SubResource("Resource_q4syt")])
event_uid = "b6713b"

[sub_resource type="Resource" id="Resource_y4urs"]
script = ExtResource("7_uikdf")
ace_id = "EmitSignal"
params = {
"args": "_queue.pop_front()",
"signal_name": "process_item"
}

[sub_resource type="Resource" id="Resource_y6j20"]
script = ExtResource("7_uikdf")
ace_id = "AddVar"
params = {
"amount": "1",
"var_name": "__n"
}

[sub_resource type="Resource" id="Resource_0hl0x"]
script = ExtResource("5_mnr22")
iterator_name = ""
collection_kind = 8
collection_value = "not _queue.is_empty()"

[sub_resource type="Resource" id="Resource_rryhb"]
script = ExtResource("8_geigq")
code = "break"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_3o7pn"]
script = ExtResource("3_q274n")
ace_id = "CompareVar"
params = {
"op": "!=",
"value": "\"count\"",
"var_name": "mode"
}

[sub_resource type="Resource" id="Resource_fs2wn"]
script = ExtResource("3_q274n")
ace_id = "CompareVar"
params = {
"op": ">=",
"value": "__budget_end",
"var_name": "Time.get_ticks_usec()"
}

[sub_resource type="Resource" id="Resource_d8iwo"]
script = ExtResource("6_pc2pk")
conditions = Array[ExtResource("3_q274n")]([SubResource("Resource_3o7pn"), SubResource("Resource_fs2wn")])
actions = Array[Resource]([SubResource("Resource_rryhb")])
