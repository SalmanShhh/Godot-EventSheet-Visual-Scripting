params = {
"op": ">=",
"value": "max_items_per_frame",
"var_name": "__n"
}

[sub_resource type="Resource" id="Resource_dr8tj"]
script = ExtResource("6_pc2pk")
conditions = Array[ExtResource("3_q274n")]([SubResource("Resource_g6f41"), SubResource("Resource_ngf8b")])
