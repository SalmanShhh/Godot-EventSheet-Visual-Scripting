[sub_resource type="Resource" id="Resource_xncmq"]
script = ExtResource("1_508eb")
text = "Timer behavior (C3-style): Start Timer / Stop Timer from any sheet; the On Timer trigger fires when it elapses (repeats when 'repeating')."

[sub_resource type="Resource" id="Resource_pt8bp"]
script = ExtResource("2_766qb")
signal_name = "timer_finished"
params = PackedStringArray()
trigger = true
ace_name = "On Timer"
ace_category = "Timer"

[sub_resource type="Resource" id="Resource_n2gek"]
script = ExtResource("3_m1bna")
ace_id = "AddVar"
params = {
"amount": "-delta",
"var_name": "remaining"
}

[sub_resource type="Resource" id="Resource_phn2u"]
script = ExtResource("4_j6rvl")
ace_id = "ExpressionIsTrue"
params = {
"expr": "running"
}

[sub_resource type="Resource" id="Resource_n42nf"]
script = ExtResource("3_m1bna")
ace_id = "EmitSignal"
params = {
"args": "",
"signal_name": "timer_finished"
}

[sub_resource type="Resource" id="Resource_rgkuy"]
script = ExtResource("4_j6rvl")
ace_id = "CompareVar"
params = {
"op": "<=",
"value": "0.0",
"var_name": "remaining"
}

[sub_resource type="Resource" id="Resource_g4shn"]
script = ExtResource("3_m1bna")
ace_id = "SetVar"
params = {
"value": "duration",
"var_name": "remaining"
}

[sub_resource type="Resource" id="Resource_wltqi"]
script = ExtResource("4_j6rvl")
ace_id = "ExpressionIsTrue"
params = {
"expr": "repeating"
}

[sub_resource type="Resource" id="Resource_sw2qi"]
script = ExtResource("7_1kfjc")
conditions = Array[ExtResource("4_j6rvl")]([SubResource("Resource_wltqi")])
actions = Array[Resource]([SubResource("Resource_g4shn")])
event_uid = "7cf227"

[sub_resource type="Resource" id="Resource_u3jr2"]
script = ExtResource("3_m1bna")
ace_id = "SetVar"
params = {
"value": "false",
"var_name": "running"
}

[sub_resource type="Resource" id="Resource_ajg5h"]
script = ExtResource("7_1kfjc")
actions = Array[Resource]([SubResource("Resource_u3jr2")])
else_mode = 1
event_uid = "8f57f0"

[sub_resource type="Resource" id="Resource_ggsot"]
script = ExtResource("7_1kfjc")
conditions = Array[ExtResource("4_j6rvl")]([SubResource("Resource_rgkuy")])
actions = Array[Resource]([SubResource("Resource_n42nf")])
sub_events = Array[Resource]([SubResource("Resource_sw2qi"), SubResource("Resource_ajg5h")])
event_uid = "670997"

[sub_resource type="Resource" id="Resource_y7dsd"]
script = ExtResource("7_1kfjc")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
conditions = Array[ExtResource("4_j6rvl")]([SubResource("Resource_phn2u")])
actions = Array[Resource]([SubResource("Resource_n2gek")])
sub_events = Array[Resource]([SubResource("Resource_ggsot")])
event_uid = "d907a5"

[sub_resource type="Resource" id="Resource_swmmw"]
script = ExtResource("3_m1bna")
ace_id = "SetVar"
params = {
"value": "seconds",
"var_name": "duration"
}

[sub_resource type="Resource" id="Resource_ey4hy"]
script = ExtResource("3_m1bna")
ace_id = "SetVar"
params = {
"value": "seconds",
"var_name": "remaining"
}

[sub_resource type="Resource" id="Resource_ctp6h"]
script = ExtResource("3_m1bna")
ace_id = "SetVar"
params = {
"value": "true",
"var_name": "running"
}

[sub_resource type="Resource" id="Resource_7y1kk"]
script = ExtResource("7_1kfjc")
actions = Array[Resource]([SubResource("Resource_swmmw"), SubResource("Resource_ey4hy"), SubResource("Resource_ctp6h")])
event_uid = "dcc443"

[sub_resource type="Resource" id="Resource_miytc"]
script = ExtResource("8_2hfnr")
id = "seconds"
type_name = "float"
initial_value = null
initialValue = null

[sub_resource type="Resource" id="Resource_ww83t"]
script = ExtResource("9_mb0oi")
function_name = "start_timer"
description = "Starts (or restarts) the countdown with the given duration."
expose_as_ace = true
ace_display_name = "Start Timer"
ace_category = "Timer"
params = Array[ExtResource("8_2hfnr")]([SubResource("Resource_miytc")])
events = Array[Resource]([SubResource("Resource_7y1kk")])

[sub_resource type="Resource" id="Resource_epjja"]
script = ExtResource("3_m1bna")
ace_id = "SetVar"
params = {
"value": "false",
"var_name": "running"
}

[sub_resource type="Resource" id="Resource_snlli"]
script = ExtResource("7_1kfjc")
actions = Array[Resource]([SubResource("Resource_epjja")])
event_uid = "1cf305"

[sub_resource type="Resource" id="Resource_4i8n2"]
script = ExtResource("9_mb0oi")
function_name = "stop_timer"
description = "Stops the countdown without firing On Timer."
expose_as_ace = true
ace_display_name = "Stop Timer"
ace_category = "Timer"
events = Array[Resource]([SubResource("Resource_snlli")])

[resource]
script = ExtResource("10_whix2")
behavior_mode = true
custom_class_name = "TimerBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_xncmq"), SubResource("Resource_pt8bp"), SubResource("Resource_y7dsd")])
variables = {
"duration": {
"default": 1.0,
"exported": true,
"type": "float"
},
"remaining": {
"default": 0.0,
"exported": false,
"type": "float"
},
"repeating": {
"default": false,
"exported": true,
"type": "bool"
},
"running": {
"default": false,
"exported": false,
"type": "bool"
}
}
functions = Array[Resource]([SubResource("Resource_ww83t"), SubResource("Resource_4i8n2")])
