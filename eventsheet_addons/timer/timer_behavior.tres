[ext_resource type="Script" path="res://addons/eventforge/resources/ace_action.gd" id="3_m1bna"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_condition.gd" id="4_j6rvl"]
[ext_resource type="Script" path="res://addons/eventforge/resources/local_variable.gd" id="5_m7th5"]
[ext_resource type="Script" path="res://addons/eventforge/resources/pick_filter.gd" id="6_uhvqa"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_row.gd" id="7_1kfjc"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_param.gd" id="8_2hfnr"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_function.gd" id="9_mb0oi"]
