[sub_resource type="Resource" id="Resource_i0mc6"]
script = ExtResource("1_3bqpc")
text = "Orbit 3D behavior (C3-style): circles the host around its starting point in the XZ plane (Y stays)."

[sub_resource type="Resource" id="Resource_51g62"]
script = ExtResource("2_1ihjn")
code = "if host == null:
	return
if not center_captured:
	center_x = host.position.x
	center_y = host.position.y
	center_z = host.position.z
	center_captured = true
angle += deg_to_rad(speed_degrees) * delta
host.position = Vector3(center_x + cos(angle) * radius, center_y, center_z + sin(angle) * radius)"

[sub_resource type="Resource" id="Resource_5urnx"]
script = ExtResource("6_6xk7j")
trigger_provider_id = "Core"
