[sub_resource type="Resource" id="Resource_5urnx"]
script = ExtResource("1_1ihjn")
text = "Orbit 3D behavior (C3-style): circles the host around its starting point in the XZ plane (Y stays)."

[sub_resource type="Resource" id="Resource_3s5dy"]
script = ExtResource("2_qhrj8")
code = "if host == null:
	return
if not center_captured:
	center_x = host.position.x
	center_y = host.position.y
	center_z = host.position.z
	center_captured = true
angle += deg_to_rad(speed_degrees) * delta
host.position = Vector3(center_x + cos(angle) * radius, center_y, center_z + sin(angle) * radius)"

[sub_resource type="Resource" id="Resource_cp8gk"]
script = ExtResource("6_2wm85")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
actions = Array[Resource]([SubResource("Resource_3s5dy")])
event_uid = "54b5dd"

[sub_resource type="Resource" id="Resource_5ogdh"]
script = ExtResource("7_crwpp")
ace_id = "SetVar"
params = {
"value": "x",
"var_name": "center_x"
}

[sub_resource type="Resource" id="Resource_snjo7"]
script = ExtResource("7_crwpp")
ace_id = "SetVar"
params = {
"value": "y",
"var_name": "center_y"
}

[sub_resource type="Resource" id="Resource_srxho"]
script = ExtResource("7_crwpp")
ace_id = "SetVar"
params = {
"value": "z",
"var_name": "center_z"
}

[sub_resource type="Resource" id="Resource_04duw"]
script = ExtResource("7_crwpp")
ace_id = "SetVar"
params = {
"value": "true",
"var_name": "center_captured"
}

[sub_resource type="Resource" id="Resource_khs5m"]
script = ExtResource("6_2wm85")
actions = Array[Resource]([SubResource("Resource_5ogdh"), SubResource("Resource_snjo7"), SubResource("Resource_srxho"), SubResource("Resource_04duw")])
event_uid = "270650"

[sub_resource type="Resource" id="Resource_7i37o"]
