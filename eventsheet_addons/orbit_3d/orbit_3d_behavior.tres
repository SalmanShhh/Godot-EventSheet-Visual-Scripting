variables = {
"angle": {
"default": 0.0,
"exported": false,
"type": "float"
},
"center_captured": {
"default": false,
"exported": false,
"type": "bool"
},
"center_x": {
"default": 0.0,
"exported": false,
"type": "float"
},
"center_y": {
"default": 0.0,
"exported": false,
"type": "float"
},
"center_z": {
"default": 0.0,
"exported": false,
"type": "float"
},
"radius": {
"default": 3.0,
"exported": true,
"type": "float"
},
"speed_degrees": {
"default": 90.0,
"exported": true,
"type": "float"
}
}
functions = Array[Resource]([SubResource("Resource_4mlo5")])
