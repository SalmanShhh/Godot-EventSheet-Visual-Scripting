[sub_resource type="Resource" id="Resource_4mlo5"]
script = ExtResource("9_i0mc6")
function_name = "set_orbit3d_center"
description = "Orbits around the given point from now on."
expose_as_ace = true
ace_display_name = "Set Orbit 3D Center"
ace_category = "Orbit 3D"
params = Array[ExtResource("8_ph37s")]([SubResource("Resource_7i37o"), SubResource("Resource_1roa2"), SubResource("Resource_d6fw4")])
events = Array[Resource]([SubResource("Resource_khs5m")])

[resource]
script = ExtResource("10_51g62")
host_class = "Node3D"
behavior_mode = true
custom_class_name = "Orbit3DBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
