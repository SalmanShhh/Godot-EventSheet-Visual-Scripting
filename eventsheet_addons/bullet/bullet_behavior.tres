ace_category = "Bullet"
params = Array[ExtResource("7_h0i2u")]([SubResource("Resource_5780g")])
events = Array[Resource]([SubResource("Resource_bw4ti")])

[sub_resource type="Resource" id="Resource_av21u"]
script = ExtResource("2_urm38")
code = "vel_x = cos(deg_to_rad(degrees)) * speed
vel_y = sin(deg_to_rad(degrees)) * speed
launched = true"

