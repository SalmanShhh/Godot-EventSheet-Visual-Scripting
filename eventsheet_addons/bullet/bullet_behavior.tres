[sub_resource type="Resource" id="Resource_dbolv"]
script = ExtResource("1_tbxl6")
text = "Bullet behavior (C3 parity): angle-of-motion movement with acceleration and gravity; tracks distance travelled (read $BulletBehavior.distance_travelled)."

[sub_resource type="Resource" id="Resource_a26d5"]
script = ExtResource("2_urm38")
code = "if host == null or not enabled_movement:
	return
if not launched:
	vel_x = cos(host.rotation) * speed
	vel_y = sin(host.rotation) * speed
	launched = true
var direction := Vector2(vel_x, vel_y).normalized()
vel_x += direction.x * acceleration * delta
vel_y += direction.y * acceleration * delta
vel_y += gravity * delta
var motion := Vector2(vel_x, vel_y) * delta
host.position += motion
distance_travelled += motion.length()
if align_rotation and motion != Vector2.ZERO:
	host.rotation = motion.angle()"

[sub_resource type="Resource" id="Resource_2c7to"]
script = ExtResource("6_eoq7w")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
actions = Array[Resource]([SubResource("Resource_a26d5")])
event_uid = "059197"

[sub_resource type="Resource" id="Resource_bw4ti"]
script = ExtResource("2_urm38")
code = "speed = value
var direction := Vector2(vel_x, vel_y).normalized()
if direction == Vector2.ZERO and host != null:
	direction = Vector2.from_angle(host.rotation)
vel_x = direction.x * value
vel_y = direction.y * value
launched = true"

[sub_resource type="Resource" id="Resource_5780g"]
script = ExtResource("7_h0i2u")
id = "value"
type_name = "float"
initial_value = null
initialValue = null

[sub_resource type="Resource" id="Resource_m8wb2"]
