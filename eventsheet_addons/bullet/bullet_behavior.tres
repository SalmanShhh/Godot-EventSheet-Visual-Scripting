[sub_resource type="Resource" id="Resource_2c7to"]
script = ExtResource("1_urm38")
text = "Bullet behavior (event-sheet parity): angle-of-motion movement with acceleration and gravity; tracks distance travelled (read $BulletBehavior.distance_travelled)."

[sub_resource type="Resource" id="Resource_bw4ti"]
script = ExtResource("6_h0i2u")
ace_id = "ReturnEarly"

[sub_resource type="Resource" id="Resource_5780g"]
script = ExtResource("2_1dpa7")
ace_id = "CompareVar"
params = {
"op": "==",
"value": "null or not enabled_movement",
"var_name": "host"
}

[sub_resource type="Resource" id="Resource_m8wb2"]
script = ExtResource("5_eoq7w")
conditions = Array[ExtResource("2_1dpa7")]([SubResource("Resource_5780g")])
actions = Array[Resource]([SubResource("Resource_bw4ti")])
event_uid = "71cf79"

[sub_resource type="Resource" id="Resource_av21u"]
script = ExtResource("6_h0i2u")
ace_id = "SetVar"
params = {
"value": "cos(host.rotation) * speed",
"var_name": "vel_x"
}

[sub_resource type="Resource" id="Resource_qvkgn"]
script = ExtResource("6_h0i2u")
ace_id = "SetVar"
params = {
"value": "sin(host.rotation) * speed",
"var_name": "vel_y"
}

[sub_resource type="Resource" id="Resource_hud1t"]
script = ExtResource("6_h0i2u")
ace_id = "SetVar"
params = {
"value": "true",
"var_name": "launched"
}

[sub_resource type="Resource" id="Resource_6l45u"]
script = ExtResource("2_1dpa7")
ace_id = "ExpressionIsTrue"
params = {
"expr": "not launched"
}

[sub_resource type="Resource" id="Resource_sjods"]
script = ExtResource("5_eoq7w")
conditions = Array[ExtResource("2_1dpa7")]([SubResource("Resource_6l45u")])
actions = Array[Resource]([SubResource("Resource_av21u"), SubResource("Resource_qvkgn"), SubResource("Resource_hud1t")])
event_uid = "902349"

[sub_resource type="Resource" id="Resource_6r2ci"]
script = ExtResource("6_h0i2u")
ace_id = "CallMethod"
params = {
"args": "",
"method": "normalized",
"target": "var direction := Vector2(vel_x, vel_y)"
}

[sub_resource type="Resource" id="Resource_1kfv6"]
script = ExtResource("6_h0i2u")
ace_id = "AddVar"
params = {
"amount": "direction.x * acceleration * delta",
"var_name": "vel_x"
}

[sub_resource type="Resource" id="Resource_vneae"]
script = ExtResource("6_h0i2u")
ace_id = "AddVar"
params = {
"amount": "direction.y * acceleration * delta",
"var_name": "vel_y"
}

[sub_resource type="Resource" id="Resource_iurpu"]
script = ExtResource("6_h0i2u")
ace_id = "AddVar"
params = {
"amount": "gravity * delta",
"var_name": "vel_y"
}

[sub_resource type="Resource" id="Resource_0g47t"]
script = ExtResource("7_0amdn")
code = "var motion := Vector2(vel_x, vel_y) * delta"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_dioae"]
script = ExtResource("6_h0i2u")
ace_id = "MoveBy2D"
params = {
"offset": "motion",
"target": "host"
}

[sub_resource type="Resource" id="Resource_6biil"]
script = ExtResource("6_h0i2u")
ace_id = "AddVar"
params = {
"amount": "motion.length()",
"var_name": "distance_travelled"
}

[sub_resource type="Resource" id="Resource_tplby"]
script = ExtResource("5_eoq7w")
actions = Array[Resource]([SubResource("Resource_6r2ci"), SubResource("Resource_1kfv6"), SubResource("Resource_vneae"), SubResource("Resource_iurpu"), SubResource("Resource_0g47t"), SubResource("Resource_dioae"), SubResource("Resource_6biil")])
event_uid = "3def62"

[sub_resource type="Resource" id="Resource_f4cxh"]
script = ExtResource("6_h0i2u")
ace_id = "SetProperty"
params = {
"property": "rotation",
"target": "host",
"value": "motion.angle()"
}

[sub_resource type="Resource" id="Resource_ncd1w"]
script = ExtResource("2_1dpa7")
ace_id = "ExpressionIsTrue"
params = {
"expr": "align_rotation"
}

[sub_resource type="Resource" id="Resource_ct6fo"]
script = ExtResource("2_1dpa7")
ace_id = "CompareVar"
params = {
"op": "!=",
"value": "Vector2.ZERO",
"var_name": "motion"
}

[sub_resource type="Resource" id="Resource_6xocv"]
script = ExtResource("5_eoq7w")
conditions = Array[ExtResource("2_1dpa7")]([SubResource("Resource_ncd1w"), SubResource("Resource_ct6fo")])
