[sub_resource type="Resource" id="Resource_p2muo"]
script = ExtResource("1_bxshy")
text = "Drag & Drop behavior (C3 parity): grab within the radius; axes locks dragging to one axis (both, horizontal, vertical). Fires On Drag Start / On Dropped."

[sub_resource type="Resource" id="Resource_u540h"]
script = ExtResource("2_bvvcx")
code = "## @ace_trigger
## @ace_name(\"On Drag Start\")
## @ace_category(\"Drag & Drop\")
signal drag_started

## @ace_trigger
## @ace_name(\"On Dropped\")
## @ace_category(\"Drag & Drop\")
signal dropped"

[sub_resource type="Resource" id="Resource_q2el6"]
script = ExtResource("2_bvvcx")
code = "if host == null:
	return
if Input.is_mouse_button_pressed(MOUSE_BUTTON_LEFT):
	var mouse := host.get_global_mouse_position()
	if not dragging and mouse.distance_to(host.global_position) <= grab_radius:
		dragging = true
		grab_x = host.global_position.x
		grab_y = host.global_position.y
		drag_started.emit()
	if dragging:
		var destination := mouse
		if axes == \"horizontal\":
			destination.y = grab_y
		elif axes == \"vertical\":
			destination.x = grab_x
		host.global_position = destination
elif dragging:
	dragging = false
	dropped.emit()"

[sub_resource type="Resource" id="Resource_0clv1"]
script = ExtResource("6_b7r38")
trigger_provider_id = "Core"
