[sub_resource type="Resource" id="Resource_2gfka"]
script = ExtResource("2_85j5o")
code = "# Overlap mode (1) gates on a derived proximity so snap_radius==0 still engages;
# radius mode (0) keeps the exact snap_radius gate.
var gate := _overlap_proximity() if snap_mode == 1 else snap_radius"
lift_note = "no matching ACE template"

