[gd_resource type="Resource" script_class="EventSheetResource" format=3]

[ext_resource type="Script" path="res://addons/eventforge/resources/comment_row.gd" id="1_q7uqc"]
[ext_resource type="Script" path="res://addons/eventforge/resources/signal_row.gd" id="2_c4ll7"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_action.gd" id="3_jlqat"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_condition.gd" id="4_wyhg1"]
[ext_resource type="Script" path="res://addons/eventforge/resources/local_variable.gd" id="5_2l66c"]
[ext_resource type="Script" path="res://addons/eventforge/resources/pick_filter.gd" id="6_xp0oq"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_row.gd" id="7_28rk4"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_param.gd" id="8_14g6j"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_function.gd" id="9_1q018"]
