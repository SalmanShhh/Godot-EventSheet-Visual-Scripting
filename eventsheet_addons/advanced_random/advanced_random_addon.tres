[sub_resource type="Resource" id="Resource_odpv0"]
script = ExtResource("1_af8dx")
text = "Advanced Random (autoload): register as the AdvancedRandom autoload, then call its ACEs from any sheet — seeded numbers/dice/normal, Perlin/Simplex noise, permutation tables, shuffle bags, weighted picks, and a Chance(%) condition. Set seed_on_start in the Inspector for reproducible runs. This pack is an event sheet — extend it by editing it."

[sub_resource type="Resource" id="Resource_fwfqp"]
script = ExtResource("2_76egj")
code = "var _rng: RandomNumberGenerator = RandomNumberGenerator.new()
var _noise: FastNoiseLite = FastNoiseLite.new()
var _perm: PackedInt32Array = PackedInt32Array()
var _bags: Dictionary = {}"

[sub_resource type="Resource" id="Resource_j6grk"]
script = ExtResource("2_76egj")
code = "if seed_on_start != 0:
	_rng.seed = seed_on_start
	_noise.seed = seed_on_start
else:
	_rng.randomize()
	_noise.seed = _rng.randi()"

