[sub_resource type="Resource" id="Resource_m0ehy"]
script = ExtResource("2_76egj")
code = "var total: float = 0.0
for weight: Variant in weights:
	total += maxf(float(weight), 0.0)
if total <= 0.0:
	return 0
var roll: float = _rng.randf() * total
var running: float = 0.0
for i: int in weights.size():
	running += maxf(float(weights[i]), 0.0)
	if roll < running:
		return i
return weights.size() - 1"

[sub_resource type="Resource" id="Resource_qu4a5"]
script = ExtResource("7_58wby")
id = "weights"
type_name = "Array"
initial_value = null
initialValue = null

