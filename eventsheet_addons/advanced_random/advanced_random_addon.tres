expose_as_ace = true
ace_display_name = "Weighted Index"
ace_category = "Advanced Random: Picking"
params = Array[ExtResource("7_58wby")]([SubResource("Resource_qu4a5")])
return_type = 2
events = Array[Resource]([SubResource("Resource_m0ehy")])

[sub_resource type="Resource" id="Resource_c341o"]
script = ExtResource("2_76egj")
code = "if not _bags.has(bag_name):
	return null
var bag: Dictionary = _bags[bag_name]
var pile: Array = bag[\"pile\"]
if pile.is_empty():
	pile = (bag[\"items\"] as Array).duplicate()
	bag[\"pile\"] = pile
if pile.is_empty():
	return null
var drawn: int = _rng.randi_range(0, pile.size() - 1)
var value: Variant = pile[drawn]
pile.remove_at(drawn)
return value"

