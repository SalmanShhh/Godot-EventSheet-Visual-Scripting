[sub_resource type="Resource" id="Resource_1dnqy"]
script = ExtResource("2_76egj")
code = "var values: Array = range(maxi(size, 0))
for i: int in range(values.size() - 1, 0, -1):
	var j: int = _rng.randi_range(0, i)
	var swap: Variant = values[i]
	values[i] = values[j]
	values[j] = swap
_perm = PackedInt32Array(values)"

