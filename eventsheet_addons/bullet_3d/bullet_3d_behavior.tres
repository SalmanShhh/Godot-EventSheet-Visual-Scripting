[sub_resource type="Resource" id="Resource_d3gnp"]
script = ExtResource("9_fp4pu")
function_name = "launch_forward"
description = "(Re)launches along the host's current forward direction."
expose_as_ace = true
ace_display_name = "Launch Forward"
ace_category = "Bullet 3D"
events = Array[Resource]([SubResource("Resource_gbdrp"), SubResource("Resource_d0fq5")])

[sub_resource type="Resource" id="Resource_dpstr"]
script = ExtResource("7_r04y7")
ace_id = "SetVar"
params = {
"value": "value",
"var_name": "speed"
}

[sub_resource type="Resource" id="Resource_ublkq"]
script = ExtResource("7_r04y7")
ace_id = "CallFunction"
params = {
"args": "vel_x, vel_y, vel_z).normalized(",
"function_name": "var direction := Vector3"
}

[sub_resource type="Resource" id="Resource_hlja7"]
script = ExtResource("6_l86d7")
actions = Array[Resource]([SubResource("Resource_dpstr"), SubResource("Resource_ublkq")])
event_uid = "11dbdb"

[sub_resource type="Resource" id="Resource_n1tj5"]
script = ExtResource("7_r04y7")
ace_id = "SetVar"
params = {
"value": "-host.global_transform.basis.z",
"var_name": "direction"
}

[sub_resource type="Resource" id="Resource_p2xyd"]
