[sub_resource type="Resource" id="Resource_wrg6a"]
script = ExtResource("1_25dsr")
text = "Bullet 3D behavior (C3-style): launches along the host's forward (-Z) with speed and gravity; tracks distance travelled."

[sub_resource type="Resource" id="Resource_5m1b1"]
script = ExtResource("2_mcy0o")
code = "if host == null:
	return
if not launched:
	launch_forward()
vel_y -= gravity * delta
var motion := Vector3(vel_x, vel_y, vel_z) * delta
host.position += motion
distance_travelled += motion.length()"

[sub_resource type="Resource" id="Resource_5abs4"]
script = ExtResource("6_l86d7")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
actions = Array[Resource]([SubResource("Resource_5m1b1")])
event_uid = "140500"

[sub_resource type="Resource" id="Resource_qs7cs"]
script = ExtResource("7_r04y7")
ace_id = "ReturnEarly"

[sub_resource type="Resource" id="Resource_i2vrm"]
script = ExtResource("3_0j3rh")
ace_id = "CompareVar"
params = {
"op": "==",
"value": "null",
"var_name": "host"
}

[sub_resource type="Resource" id="Resource_gbdrp"]
script = ExtResource("6_l86d7")
conditions = Array[ExtResource("3_0j3rh")]([SubResource("Resource_i2vrm")])
actions = Array[Resource]([SubResource("Resource_qs7cs")])
event_uid = "04cb94"

[sub_resource type="Resource" id="Resource_frt6g"]
script = ExtResource("2_mcy0o")
code = "var forward := -host.global_transform.basis.z * speed"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_djup5"]
script = ExtResource("7_r04y7")
