"var_name": "vel_y"
}

[sub_resource type="Resource" id="Resource_1235k"]
script = ExtResource("7_r04y7")
ace_id = "SetVar"
params = {
"value": "forward.z",
"var_name": "vel_z"
}

[sub_resource type="Resource" id="Resource_0ftvu"]
script = ExtResource("7_r04y7")
ace_id = "SetVar"
params = {
"value": "true",
"var_name": "launched"
}

[sub_resource type="Resource" id="Resource_d0fq5"]
script = ExtResource("6_l86d7")
actions = Array[Resource]([SubResource("Resource_frt6g"), SubResource("Resource_djup5"), SubResource("Resource_34qr1"), SubResource("Resource_1235k"), SubResource("Resource_0ftvu")])
