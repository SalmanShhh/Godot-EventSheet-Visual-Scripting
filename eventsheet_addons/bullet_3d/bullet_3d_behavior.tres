[ext_resource type="Script" path="res://addons/eventforge/resources/ace_condition.gd" id="2_mcy0o"]
[ext_resource type="Script" path="res://addons/eventforge/resources/local_variable.gd" id="3_0j3rh"]
[ext_resource type="Script" path="res://addons/eventforge/resources/pick_filter.gd" id="4_elqwn"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_row.gd" id="5_n4o3h"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_action.gd" id="6_l86d7"]
[ext_resource type="Script" path="res://addons/eventforge/resources/raw_code_row.gd" id="7_r04y7"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_param.gd" id="8_nss1k"]
