[sub_resource type="Resource" id="Resource_wrg6a"]
script = ExtResource("1_25dsr")
text = "Bullet 3D behavior (event-sheet-style): launches along the host's forward (-Z) with speed and gravity; tracks distance travelled."

[sub_resource type="Resource" id="Resource_5m1b1"]
script = ExtResource("6_l86d7")
ace_id = "ReturnEarly"

[sub_resource type="Resource" id="Resource_5abs4"]
script = ExtResource("2_mcy0o")
ace_id = "CompareVar"
params = {
"op": "==",
"value": "null",
"var_name": "host"
}

[sub_resource type="Resource" id="Resource_qs7cs"]
script = ExtResource("5_n4o3h")
conditions = Array[ExtResource("2_mcy0o")]([SubResource("Resource_5abs4")])
actions = Array[Resource]([SubResource("Resource_5m1b1")])
event_uid = "6a7e46"

[sub_resource type="Resource" id="Resource_i2vrm"]
script = ExtResource("6_l86d7")
ace_id = "CallFunction"
params = {
"args": "",
"function_name": "launch_forward"
}

[sub_resource type="Resource" id="Resource_gbdrp"]
script = ExtResource("2_mcy0o")
ace_id = "ExpressionIsTrue"
params = {
"expr": "not launched"
}

[sub_resource type="Resource" id="Resource_frt6g"]
script = ExtResource("5_n4o3h")
conditions = Array[ExtResource("2_mcy0o")]([SubResource("Resource_gbdrp")])
actions = Array[Resource]([SubResource("Resource_i2vrm")])
event_uid = "b25c00"

[sub_resource type="Resource" id="Resource_djup5"]
script = ExtResource("6_l86d7")
ace_id = "SubtractVar"
params = {
"amount": "gravity * delta",
"var_name": "vel_y"
}

[sub_resource type="Resource" id="Resource_34qr1"]
script = ExtResource("7_r04y7")
code = "var motion := Vector3(vel_x, vel_y, vel_z) * delta"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_1235k"]
script = ExtResource("6_l86d7")
ace_id = "MoveBy2D"
params = {
"offset": "motion",
"target": "host"
}

[sub_resource type="Resource" id="Resource_0ftvu"]
script = ExtResource("6_l86d7")
ace_id = "AddVar"
params = {
"amount": "motion.length()",
"var_name": "distance_travelled"
}

[sub_resource type="Resource" id="Resource_d0fq5"]
script = ExtResource("5_n4o3h")
actions = Array[Resource]([SubResource("Resource_djup5"), SubResource("Resource_34qr1"), SubResource("Resource_1235k"), SubResource("Resource_0ftvu")])
event_uid = "ab2735"

[sub_resource type="Resource" id="Resource_d3gnp"]
script = ExtResource("5_n4o3h")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
sub_events = Array[Resource]([SubResource("Resource_qs7cs"), SubResource("Resource_frt6g"), SubResource("Resource_d0fq5")])
event_uid = "140500"

[sub_resource type="Resource" id="Resource_dpstr"]
script = ExtResource("6_l86d7")
ace_id = "ReturnEarly"

[sub_resource type="Resource" id="Resource_ublkq"]
script = ExtResource("2_mcy0o")
ace_id = "CompareVar"
params = {
"op": "==",
"value": "null",
"var_name": "host"
}

[sub_resource type="Resource" id="Resource_hlja7"]
script = ExtResource("5_n4o3h")
conditions = Array[ExtResource("2_mcy0o")]([SubResource("Resource_ublkq")])
actions = Array[Resource]([SubResource("Resource_dpstr")])
event_uid = "04cb94"

[sub_resource type="Resource" id="Resource_n1tj5"]
script = ExtResource("7_r04y7")
code = "var forward := -host.global_transform.basis.z * speed"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_p2xyd"]
script = ExtResource("6_l86d7")
ace_id = "SetVar"
params = {
"value": "forward.x",
"var_name": "vel_x"
}

[sub_resource type="Resource" id="Resource_m8uf3"]
script = ExtResource("6_l86d7")
ace_id = "SetVar"
params = {
"value": "forward.y",
"var_name": "vel_y"
}

[sub_resource type="Resource" id="Resource_217e4"]
script = ExtResource("6_l86d7")
ace_id = "SetVar"
params = {
"value": "forward.z",
"var_name": "vel_z"
}

[sub_resource type="Resource" id="Resource_ijvk6"]
script = ExtResource("6_l86d7")
ace_id = "SetVar"
params = {
"value": "true",
"var_name": "launched"
}

[sub_resource type="Resource" id="Resource_o4eib"]
script = ExtResource("5_n4o3h")
actions = Array[Resource]([SubResource("Resource_n1tj5"), SubResource("Resource_p2xyd"), SubResource("Resource_m8uf3"), SubResource("Resource_217e4"), SubResource("Resource_ijvk6")])
event_uid = "5c7602"

[sub_resource type="Resource" id="Resource_8ek4r"]
script = ExtResource("9_fp4pu")
function_name = "launch_forward"
description = "(Re)launches along the host's current forward direction."
expose_as_ace = true
ace_display_name = "Launch Forward"
ace_category = "Bullet 3D"
events = Array[Resource]([SubResource("Resource_hlja7"), SubResource("Resource_o4eib")])

[sub_resource type="Resource" id="Resource_56ejy"]
script = ExtResource("6_l86d7")
ace_id = "SetVar"
params = {
"value": "value",
"var_name": "speed"
}

[sub_resource type="Resource" id="Resource_iip6r"]
script = ExtResource("6_l86d7")
ace_id = "CallMethod"
params = {
"args": "",
"method": "normalized",
"target": "var direction := Vector3(vel_x, vel_y, vel_z)"
}

[sub_resource type="Resource" id="Resource_xsnux"]
script = ExtResource("5_n4o3h")
actions = Array[Resource]([SubResource("Resource_56ejy"), SubResource("Resource_iip6r")])
event_uid = "11dbdb"

[sub_resource type="Resource" id="Resource_8sdwv"]
script = ExtResource("6_l86d7")
ace_id = "SetVar"
params = {
"value": "-host.global_transform.basis.z",
"var_name": "direction"
}

[sub_resource type="Resource" id="Resource_s2sxn"]
script = ExtResource("2_mcy0o")
ace_id = "CompareVar"
params = {
"op": "==",
"value": "Vector3.ZERO",
"var_name": "direction"
}

[sub_resource type="Resource" id="Resource_bkh2v"]
script = ExtResource("2_mcy0o")
ace_id = "CompareVar"
params = {
"op": "!=",
"value": "null",
"var_name": "host"
}

[sub_resource type="Resource" id="Resource_3a21s"]
script = ExtResource("5_n4o3h")
conditions = Array[ExtResource("2_mcy0o")]([SubResource("Resource_s2sxn"), SubResource("Resource_bkh2v")])
actions = Array[Resource]([SubResource("Resource_8sdwv")])
event_uid = "554233"

[sub_resource type="Resource" id="Resource_alb4r"]
script = ExtResource("6_l86d7")
ace_id = "SetVar"
params = {
"value": "direction.x * value",
"var_name": "vel_x"
}

[sub_resource type="Resource" id="Resource_i6d6t"]
script = ExtResource("6_l86d7")
ace_id = "SetVar"
params = {
"value": "direction.y * value",
"var_name": "vel_y"
}

[sub_resource type="Resource" id="Resource_xarue"]
script = ExtResource("6_l86d7")
ace_id = "SetVar"
params = {
"value": "direction.z * value",
"var_name": "vel_z"
}

[sub_resource type="Resource" id="Resource_8mewk"]
script = ExtResource("6_l86d7")
ace_id = "SetVar"
params = {
"value": "true",
"var_name": "launched"
}

[sub_resource type="Resource" id="Resource_6gv7t"]
script = ExtResource("5_n4o3h")
actions = Array[Resource]([SubResource("Resource_alb4r"), SubResource("Resource_i6d6t"), SubResource("Resource_xarue"), SubResource("Resource_8mewk")])
event_uid = "7e46c4"

[sub_resource type="Resource" id="Resource_ncqgk"]
script = ExtResource("8_nss1k")
id = "value"
type_name = "float"
initial_value = null
initialValue = null

[sub_resource type="Resource" id="Resource_fdgqe"]
script = ExtResource("9_fp4pu")
function_name = "set_bullet3d_speed"
description = "Changes speed, keeping the current direction."
expose_as_ace = true
ace_display_name = "Set Bullet 3D Speed"
ace_category = "Bullet 3D"
params = Array[ExtResource("8_nss1k")]([SubResource("Resource_ncqgk")])
events = Array[Resource]([SubResource("Resource_xsnux"), SubResource("Resource_3a21s"), SubResource("Resource_6gv7t")])

[resource]
script = ExtResource("10_iaqmi")
host_class = "Node3D"
behavior_mode = true
custom_class_name = "Bullet3DBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_wrg6a"), SubResource("Resource_d3gnp")])
variables = {
"distance_travelled": {
"default": 0.0,
"exported": false,
"type": "float"
},
"gravity": {
"default": 0.0,
"exported": true,
"type": "float"
},
"launched": {
"default": false,
"exported": false,
"type": "bool"
},
"speed": {
"default": 10.0,
"exported": true,
"type": "float"
},
"vel_x": {
"default": 0.0,
"exported": false,
"type": "float"
},
"vel_y": {
"default": 0.0,
"exported": false,
"type": "float"
},
"vel_z": {
"default": 0.0,
"exported": false,
"type": "float"
}
}
functions = Array[Resource]([SubResource("Resource_8ek4r"), SubResource("Resource_fdgqe")])
