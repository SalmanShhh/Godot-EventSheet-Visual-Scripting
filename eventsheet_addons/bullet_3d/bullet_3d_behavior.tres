params = {
"op": "==",
"value": "Vector3.ZERO",
"var_name": "direction"
}

[sub_resource type="Resource" id="Resource_m8uf3"]
script = ExtResource("3_0j3rh")
ace_id = "CompareVar"
params = {
"op": "!=",
"value": "null",
"var_name": "host"
}

