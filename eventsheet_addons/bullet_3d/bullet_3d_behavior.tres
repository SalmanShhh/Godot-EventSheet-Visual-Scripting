"default": 0.0,
"exported": false,
"type": "float"
},
"gravity": {
"default": 0.0,
"exported": true,
"type": "float"
},
"launched": {
"default": false,
"exported": false,
"type": "bool"
},
"speed": {
"default": 10.0,
"exported": true,
"type": "float"
},
"vel_x": {
"default": 0.0,
"exported": false,
"type": "float"
},
"vel_y": {
"default": 0.0,
"exported": false,
"type": "float"
},
"vel_z": {
"default": 0.0,
"exported": false,
"type": "float"
}
}
