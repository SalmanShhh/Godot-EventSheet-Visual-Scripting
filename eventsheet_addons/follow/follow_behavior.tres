[sub_resource type="Resource" id="Resource_ycohw"]
script = ExtResource("1_3pe77")
text = "Follow behavior (C3 parity): trails another node. mode smooth = lerp chase; mode delayed = replay the target's position history after a delay (C3's Follow)."

[sub_resource type="Resource" id="Resource_bov8v"]
script = ExtResource("2_me8t3")
code = "## @ace_trigger
## @ace_name(\"On Reached Target\")
## @ace_category(\"Follow\")
signal reached_target"

[sub_resource type="Resource" id="Resource_c7vdw"]
script = ExtResource("2_me8t3")
code = "if host == null or target_path == \"\":
	return
var target := host.get_node_or_null(NodePath(target_path))
if not (target is Node2D):
	return
clock += delta
history.append([clock, target.position])
while history.size() > 2 and float(history[0][0]) < clock - delay - 1.0:
	history.pop_front()
if not following:
	return
if mode == \"delayed\":
	var sample_time := clock - delay
	for entry: Array in history:
		if float(entry[0]) >= sample_time:
			host.position = entry[1]
			break
	return
if host.position.distance_to(target.position) <= min_distance:
	if not _reached:
		_reached = true
		reached_target.emit()
	return
_reached = false
host.position = host.position.lerp(target.position, clampf(follow_speed * delta, 0.0, 1.0))"

[sub_resource type="Resource" id="Resource_na37c"]
script = ExtResource("6_jjqsf")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
actions = Array[Resource]([SubResource("Resource_c7vdw")])
event_uid = "3bb3c2"

[sub_resource type="Resource" id="Resource_5y2vt"]
script = ExtResource("2_me8t3")
code = "target_path = path
following = true
history = []"

[sub_resource type="Resource" id="Resource_eu4p6"]
script = ExtResource("7_l3qb0")
id = "path"
initial_value = null
initialValue = null

[sub_resource type="Resource" id="Resource_r3cqn"]
script = ExtResource("8_oywdo")
function_name = "start_following"
description = "Follows the node at the given path."
expose_as_ace = true
ace_display_name = "Start Following"
ace_category = "Follow"
params = Array[ExtResource("7_l3qb0")]([SubResource("Resource_eu4p6")])
events = Array[Resource]([SubResource("Resource_5y2vt")])

[sub_resource type="Resource" id="Resource_k8t8f"]
script = ExtResource("2_me8t3")
code = "following = false"

[sub_resource type="Resource" id="Resource_mavc5"]
script = ExtResource("8_oywdo")
function_name = "stop_following"
description = "Stops trailing the target."
expose_as_ace = true
ace_display_name = "Stop Following"
ace_category = "Follow"
events = Array[Resource]([SubResource("Resource_k8t8f")])

[resource]
script = ExtResource("9_8eb11")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "FollowBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_ycohw"), SubResource("Resource_bov8v"), SubResource("Resource_na37c")])
variables = {
"_reached": {
"default": false,
"exported": false,
"type": "bool"
},
"clock": {
"default": 0.0,
"exported": false,
"type": "float"
},
"delay": {
"default": 0.4,
"exported": true,
"type": "float"
},
"follow_speed": {
"default": 5.0,
"exported": true,
"type": "float"
},
"following": {
"default": true,
"exported": false,
"type": "bool"
},
"history": {
"default": [],
"exported": false,
"type": "Array"
},
"min_distance": {
"default": 0.0,
"exported": true,
"type": "float"
},
"mode": {
"default": "smooth",
"exported": true,
"options": ["smooth", "delayed"],
"type": "String"
},
"target_path": {
"default": "",
"exported": true,
"type": "String"
}
}
functions = Array[Resource]([SubResource("Resource_r3cqn"), SubResource("Resource_mavc5")])
