[resource]
script = ExtResource("11_na37c")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "FollowBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_5y2vt"), SubResource("Resource_eu4p6"), SubResource("Resource_k8t8f")])
variables = {
"_reached": {
"default": false,
"exported": false,
"type": "bool"
},
"clock": {
"default": 0.0,
"exported": false,
"type": "float"
},
"delay": {
"default": 0.4,
"exported": true,
"type": "float"
},
"follow_speed": {
"default": 5.0,
"exported": true,
"type": "float"
},
"following": {
"default": true,
"exported": false,
"type": "bool"
},
"history": {
"default": [],
"exported": false,
"type": "Array"
},
"min_distance": {
"default": 0.0,
"exported": true,
"type": "float"
},
"mode": {
"default": "smooth",
"exported": true,
"options": ["smooth", "delayed"],
"type": "String"
},
"target_path": {
"default": "",
"exported": true,
"type": "String"
}
}
functions = Array[Resource]([SubResource("Resource_nq2pf"), SubResource("Resource_ya7es")])
