[sub_resource type="Resource" id="Resource_y7j0k"]
script = ExtResource("1_1yoqm")
text = "Flash behavior (C3-style): blinks the host's visibility for a duration, then restores it and fires On Flash Finished."

[sub_resource type="Resource" id="Resource_dftwn"]
script = ExtResource("2_5x47p")
signal_name = "flash_finished"
params = PackedStringArray()
trigger = true
ace_name = "On Flash Finished"
ace_category = "Flash"

[sub_resource type="Resource" id="Resource_r8mfy"]
script = ExtResource("3_em10l")
ace_id = "AddVar"
params = {
"amount": "-delta",
"var_name": "remaining"
}

[sub_resource type="Resource" id="Resource_avg4v"]
script = ExtResource("3_em10l")
ace_id = "AddVar"
params = {
"amount": "delta",
"var_name": "accumulator"
}

[sub_resource type="Resource" id="Resource_31bce"]
script = ExtResource("4_yaapd")
ace_id = "ExpressionIsTrue"
params = {
"expr": "flashing"
}

[sub_resource type="Resource" id="Resource_cg5ak"]
script = ExtResource("4_yaapd")
ace_id = "IsValid"
params = {
"target": "host"
}

[sub_resource type="Resource" id="Resource_dnxji"]
script = ExtResource("3_em10l")
ace_id = "SetVar"
params = {
"value": "0.0",
"var_name": "accumulator"
}

[sub_resource type="Resource" id="Resource_isly2"]
script = ExtResource("3_em10l")
ace_id = "SetProperty"
params = {
"property": "visible",
"target": "host",
"value": "not host.visible"
}

[sub_resource type="Resource" id="Resource_2gkl5"]
script = ExtResource("4_yaapd")
ace_id = "CompareVar"
params = {
"op": ">=",
"value": "interval",
"var_name": "accumulator"
}

[sub_resource type="Resource" id="Resource_stf77"]
script = ExtResource("7_d46t5")
conditions = Array[ExtResource("4_yaapd")]([SubResource("Resource_2gkl5")])
actions = Array[Resource]([SubResource("Resource_dnxji"), SubResource("Resource_isly2")])
event_uid = "207a45"

[sub_resource type="Resource" id="Resource_0d12k"]
script = ExtResource("3_em10l")
ace_id = "SetVar"
params = {
"value": "false",
"var_name": "flashing"
}

[sub_resource type="Resource" id="Resource_nmgyj"]
script = ExtResource("3_em10l")
ace_id = "SetProperty"
params = {
"property": "visible",
"target": "host",
"value": "true"
}

[sub_resource type="Resource" id="Resource_v4ad3"]
script = ExtResource("3_em10l")
ace_id = "EmitSignal"
params = {
"args": "",
"signal_name": "flash_finished"
}

[sub_resource type="Resource" id="Resource_ywpx7"]
script = ExtResource("4_yaapd")
ace_id = "CompareVar"
params = {
"op": "<=",
"value": "0.0",
"var_name": "remaining"
}

[sub_resource type="Resource" id="Resource_yitlq"]
script = ExtResource("7_d46t5")
conditions = Array[ExtResource("4_yaapd")]([SubResource("Resource_ywpx7")])
actions = Array[Resource]([SubResource("Resource_0d12k"), SubResource("Resource_nmgyj"), SubResource("Resource_v4ad3")])
event_uid = "c34c6f"

[sub_resource type="Resource" id="Resource_874q3"]
script = ExtResource("7_d46t5")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
conditions = Array[ExtResource("4_yaapd")]([SubResource("Resource_31bce"), SubResource("Resource_cg5ak")])
actions = Array[Resource]([SubResource("Resource_r8mfy"), SubResource("Resource_avg4v")])
sub_events = Array[Resource]([SubResource("Resource_stf77"), SubResource("Resource_yitlq")])
event_uid = "443573"

[sub_resource type="Resource" id="Resource_ljheh"]
script = ExtResource("3_em10l")
ace_id = "SetVar"
params = {
"value": "seconds",
"var_name": "remaining"
}

[sub_resource type="Resource" id="Resource_yvdm6"]
script = ExtResource("3_em10l")
ace_id = "SetVar"
params = {
"value": "0.0",
"var_name": "accumulator"
}

[sub_resource type="Resource" id="Resource_a0jvy"]
script = ExtResource("3_em10l")
ace_id = "SetVar"
params = {
"value": "true",
"var_name": "flashing"
}

[sub_resource type="Resource" id="Resource_burpv"]
script = ExtResource("7_d46t5")
actions = Array[Resource]([SubResource("Resource_ljheh"), SubResource("Resource_yvdm6"), SubResource("Resource_a0jvy")])
event_uid = "c9cffc"

[sub_resource type="Resource" id="Resource_87baa"]
script = ExtResource("8_hpxd0")
id = "seconds"
type_name = "float"
initial_value = null
initialValue = null

[sub_resource type="Resource" id="Resource_7a2os"]
script = ExtResource("9_1uias")
function_name = "flash"
description = "Blinks the host for the given number of seconds."
expose_as_ace = true
ace_display_name = "Flash"
ace_category = "Flash"
params = Array[ExtResource("8_hpxd0")]([SubResource("Resource_87baa")])
events = Array[Resource]([SubResource("Resource_burpv")])

[sub_resource type="Resource" id="Resource_q6oly"]
script = ExtResource("3_em10l")
ace_id = "SetVar"
params = {
"value": "false",
"var_name": "flashing"
}

[sub_resource type="Resource" id="Resource_834h2"]
script = ExtResource("7_d46t5")
actions = Array[Resource]([SubResource("Resource_q6oly")])
event_uid = "ab1469"

[sub_resource type="Resource" id="Resource_10cfi"]
script = ExtResource("3_em10l")
ace_id = "SetProperty"
params = {
"property": "visible",
"target": "host",
"value": "true"
}

[sub_resource type="Resource" id="Resource_1a7l4"]
script = ExtResource("4_yaapd")
ace_id = "IsValid"
params = {
"target": "host"
}

[sub_resource type="Resource" id="Resource_pfxob"]
script = ExtResource("7_d46t5")
conditions = Array[ExtResource("4_yaapd")]([SubResource("Resource_1a7l4")])
actions = Array[Resource]([SubResource("Resource_10cfi")])
event_uid = "fc19ea"

[sub_resource type="Resource" id="Resource_ksa6n"]
script = ExtResource("9_1uias")
function_name = "stop_flash"
description = "Stops flashing and restores visibility."
expose_as_ace = true
ace_display_name = "Stop Flash"
ace_category = "Flash"
events = Array[Resource]([SubResource("Resource_834h2"), SubResource("Resource_pfxob")])

[resource]
script = ExtResource("10_it4ek")
host_class = "CanvasItem"
behavior_mode = true
custom_class_name = "FlashBehavior"
addon_tags = PackedStringArray()
events = Array[Resource]([SubResource("Resource_y7j0k"), SubResource("Resource_dftwn"), SubResource("Resource_874q3")])
variables = {
"accumulator": {
"default": 0.0,
"exported": false,
"type": "float"
},
"flashing": {
"default": false,
"exported": false,
"type": "bool"
},
"interval": {
"default": 0.1,
"exported": true,
"type": "float"
},
"remaining": {
"default": 0.0,
"exported": false,
"type": "float"
}
}
functions = Array[Resource]([SubResource("Resource_7a2os"), SubResource("Resource_ksa6n")])
