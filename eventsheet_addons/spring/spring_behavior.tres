[resource]
script = ExtResource("11_22bip")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "SpringBehavior"
addon_tags = PackedStringArray("motion", "juice")
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_dn21t"), SubResource("Resource_iqxm8"), SubResource("Resource_o5f7p"), SubResource("Resource_er0il"), SubResource("Resource_rugel")])
variables = {
"color_springs": {
"default": {},
"exported": false,
"type": "Dictionary"
},
"default_damping": {
"attributes": {
"range": {
"max": "1",
"min": "0",
"step": "0.01"
},
"tooltip": "0 = oscillate forever, 1 = no overshoot."
},
"default": 0.85,
"exported": true,
"type": "float"
},
"default_precision": {
"attributes": {
"tooltip": "Distance + speed below which a spring counts as settled."
},
"default": 0.01,
"exported": true,
"type": "float"
},
"default_stiffness": {
"attributes": {
"range": {
"max": "1000",
"min": "1",
"step": "1"
},
"tooltip": "Spring force toward the target (higher = snappier)."
},
"default": 170.0,
"exported": true,
"type": "float"
},
"springs": {
"default": {},
"exported": false,
"type": "Dictionary"
}
}
functions = Array[Resource]([SubResource("Resource_vy162"), SubResource("Resource_qpwek"), SubResource("Resource_ok433"), SubResource("Resource_tl340"), SubResource("Resource_w43bg"), SubResource("Resource_0cnhx"), SubResource("Resource_1libp"), SubResource("Resource_ya0rd"), SubResource("Resource_4v6rf"), SubResource("Resource_3jjoe"), SubResource("Resource_t8fj2"), SubResource("Resource_d3i6q"), SubResource("Resource_6x6i7"), SubResource("Resource_vq032"), SubResource("Resource_pygyx"), SubResource("Resource_gm4yt")])
