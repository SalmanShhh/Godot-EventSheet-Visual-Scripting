[resource]
script = ExtResource("9_0olq3")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "SpringBehavior"
addon_tags = PackedStringArray("motion", "juice")
events = Array[Resource]([SubResource("Resource_swf5b"), SubResource("Resource_kefu4"), SubResource("Resource_22bip")])
variables = {
"color_springs": {
"default": {},
"exported": false,
"type": "Dictionary"
},
"default_damping": {
"attributes": {
"range": {
"max": "1",
"min": "0",
"step": "0.01"
},
"tooltip": "0 = oscillate forever, 1 = no overshoot."
},
"default": 0.85,
"exported": true,
"type": "float"
},
"default_precision": {
"attributes": {
"tooltip": "Distance + speed below which a spring counts as settled."
},
"default": 0.01,
"exported": true,
"type": "float"
},
"default_stiffness": {
"attributes": {
"range": {
"max": "1000",
"min": "1",
"step": "1"
},
"tooltip": "Spring force toward the target (higher = snappier)."
},
"default": 170.0,
"exported": true,
"type": "float"
},
"springs": {
"default": {},
"exported": false,
"type": "Dictionary"
}
}
