[resource]
script = ExtResource("10_kefu4")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "SpringBehavior"
addon_tags = PackedStringArray("motion", "juice")
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_m7rga"), SubResource("Resource_22bip"), SubResource("Resource_iqxm8")])
variables = {
"color_springs": {
"default": {},
"exported": false,
"type": "Dictionary"
},
"default_damping": {
"attributes": {
"range": {
"max": "1",
"min": "0",
"step": "0.01"
},
"tooltip": "0 = oscillate forever, 1 = no overshoot."
},
"default": 0.85,
"exported": true,
"type": "float"
},
"default_precision": {
"attributes": {
"tooltip": "Distance + speed below which a spring counts as settled."
},
"default": 0.01,
"exported": true,
"type": "float"
},
"default_stiffness": {
"attributes": {
"range": {
"max": "1000",
"min": "1",
"step": "1"
},
"tooltip": "Spring force toward the target (higher = snappier)."
},
"default": 170.0,
"exported": true,
"type": "float"
},
"springs": {
"default": {},
"exported": false,
"type": "Dictionary"
}
}
functions = Array[Resource]([SubResource("Resource_hd6c3"), SubResource("Resource_d02j4"), SubResource("Resource_y6r42"), SubResource("Resource_prh0a"), SubResource("Resource_nf08y"), SubResource("Resource_2k8ji"), SubResource("Resource_013s2"), SubResource("Resource_47k71"), SubResource("Resource_nq58w"), SubResource("Resource_jkqxu"), SubResource("Resource_ml287"), SubResource("Resource_0m3x7"), SubResource("Resource_t8fj2"), SubResource("Resource_qjqk4"), SubResource("Resource_t6kd5"), SubResource("Resource_bj1xb")])
