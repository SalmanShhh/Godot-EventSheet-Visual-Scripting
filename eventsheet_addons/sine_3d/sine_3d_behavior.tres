[resource]
script = ExtResource("10_w5wfh")
host_class = "Node3D"
behavior_mode = true
custom_class_name = "Sine3DBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_pe8wu"), SubResource("Resource_wu8f5"), SubResource("Resource_a1d3g")])
variables = {
"active": {
"default": true,
"exported": true,
"type": "bool"
},
"base_captured": {
"default": false,
"exported": false,
"type": "bool"
},
"base_rot_y": {
"default": 0.0,
"exported": false,
"type": "float"
},
"base_x": {
"default": 0.0,
"exported": false,
"type": "float"
},
"base_y": {
"default": 0.0,
"exported": false,
"type": "float"
},
"base_z": {
"default": 0.0,
"exported": false,
"type": "float"
},
"magnitude": {
"default": 2.0,
"exported": true,
"type": "float"
},
"movement": {
"default": "y",
"exported": true,
"options": ["x", "y", "z", "rotation-y"],
"type": "String"
},
"period": {
"default": 4.0,
"exported": true,
"type": "float"
},
"phase_degrees": {
"default": 0.0,
"exported": true,
"type": "float"
},
"time": {
"default": 0.0,
"exported": false,
"type": "float"
},
"wave": {
"default": "sine",
"exported": true,
"options": ["sine", "triangle", "sawtooth", "reverse-sawtooth", "square"],
"type": "String"
}
}
functions = Array[Resource]([SubResource("Resource_guuhh"), SubResource("Resource_e1kfv"), SubResource("Resource_8c033")])
