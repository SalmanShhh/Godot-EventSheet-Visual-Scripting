[sub_resource type="Resource" id="Resource_6dce3"]
script = ExtResource("2_ron22")
code = "var t := time / maxf(period, 0.001) + phase_degrees / 360.0
var offset := _wave(t) * magnitude"
lift_note = "no matching ACE template"

