[ext_resource type="Script" path="res://addons/eventforge/resources/ace_condition.gd" id="2_5mxdm"]
[ext_resource type="Script" path="res://addons/eventforge/resources/local_variable.gd" id="3_x8d86"]
[ext_resource type="Script" path="res://addons/eventforge/resources/pick_filter.gd" id="4_j4ynf"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_row.gd" id="5_whq3n"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_action.gd" id="6_bff3u"]
[ext_resource type="Script" path="res://addons/eventforge/resources/raw_code_row.gd" id="7_6c0uw"]
[ext_resource type="Script" path="res://addons/eventforge/resources/ace_param.gd" id="8_526kk"]
[ext_resource type="Script" path="res://addons/eventforge/resources/event_function.gd" id="9_w5wfh"]
