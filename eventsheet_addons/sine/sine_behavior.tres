[sub_resource type="Resource" id="Resource_h7qyd"]
script = ExtResource("6_wp66b")
ace_id = "CallFunction"
params = {
"args": "t, 1.0",
"function_name": "var cycle := fposmod"
}

[sub_resource type="Resource" id="Resource_qei8s"]
script = ExtResource("10_733ur")
match_expression = "wave"
branches_text = "\"triangle\":
	return 1.0 - 4.0 * absf(cycle - 0.5)
\"sawtooth\":
	return 2.0 * cycle - 1.0
\"reverse-sawtooth\":
	return 1.0 - 2.0 * cycle
\"square\":
	return 1.0 if cycle < 0.5 else -1.0"

[sub_resource type="Resource" id="Resource_7ypt1"]
script = ExtResource("6_wp66b")
ace_id = "ReturnValue"
params = {
"value": "sin(cycle * TAU)"
}

[sub_resource type="Resource" id="Resource_66ash"]
script = ExtResource("5_ma42h")
actions = Array[Resource]([SubResource("Resource_h7qyd"), SubResource("Resource_qei8s"), SubResource("Resource_7ypt1")])
event_uid = "c468ba"

