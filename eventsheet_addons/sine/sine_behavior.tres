[sub_resource type="Resource" id="Resource_1wlap"]
script = ExtResource("1_6dloj")
text = "Sine behavior (event-sheet parity): wave-driven oscillation. movement: horizontal, vertical, forwards-backwards, size, angle, opacity, value-only. wave: sine, triangle, sawtooth, reverse-sawtooth, square. Read the current wave via $SineBehavior.wave_value."

[sub_resource type="Resource" id="Resource_2rghd"]
script = ExtResource("6_wp66b")
ace_id = "ReturnEarly"

[sub_resource type="Resource" id="Resource_1s08y"]
script = ExtResource("2_ctwty")
ace_id = "CompareVar"
params = {
"op": "active",
"value": "or host == null",
"var_name": "not"
}

[sub_resource type="Resource" id="Resource_pkkss"]
script = ExtResource("5_ma42h")
conditions = Array[ExtResource("2_ctwty")]([SubResource("Resource_1s08y")])
actions = Array[Resource]([SubResource("Resource_2rghd")])
event_uid = "8e4a51"

[sub_resource type="Resource" id="Resource_lkxsk"]
script = ExtResource("6_wp66b")
ace_id = "CallFunction"
params = {
"args": "",
"function_name": "update_initial_state"
}

[sub_resource type="Resource" id="Resource_dtsks"]
script = ExtResource("2_ctwty")
ace_id = "ExpressionIsTrue"
params = {
"expr": "not base_captured"
}

[sub_resource type="Resource" id="Resource_tj40q"]
script = ExtResource("5_ma42h")
conditions = Array[ExtResource("2_ctwty")]([SubResource("Resource_dtsks")])
actions = Array[Resource]([SubResource("Resource_lkxsk")])
event_uid = "488a6b"

[sub_resource type="Resource" id="Resource_bbyxi"]
script = ExtResource("6_wp66b")
ace_id = "AddVar"
params = {
"amount": "delta",
"var_name": "time"
}

[sub_resource type="Resource" id="Resource_2adsf"]
script = ExtResource("7_lul5e")
code = "var t := time / maxf(period, 0.001) + phase_degrees / 360.0"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_nlxt1"]
script = ExtResource("6_wp66b")
ace_id = "SetVar"
params = {
"value": "_wave(t)",
"var_name": "wave_value"
}

[sub_resource type="Resource" id="Resource_o7e8v"]
script = ExtResource("7_lul5e")
code = "var offset := wave_value * magnitude"
lift_note = "no matching ACE template"

[sub_resource type="Resource" id="Resource_cihmo"]
script = ExtResource("5_ma42h")
actions = Array[Resource]([SubResource("Resource_bbyxi"), SubResource("Resource_2adsf"), SubResource("Resource_nlxt1"), SubResource("Resource_o7e8v")])
event_uid = "086a5e"

[sub_resource type="Resource" id="Resource_w7ecx"]
script = ExtResource("6_wp66b")
ace_id = "SetProperty"
params = {
"property": "position.x",
"target": "host",
"value": "base_x + offset"
}

