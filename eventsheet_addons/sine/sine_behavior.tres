return_type = 3
events = Array[Resource]([SubResource("Resource_66ash")])

[resource]
script = ExtResource("11_81y13")
host_class = "Node2D"
behavior_mode = true
custom_class_name = "SineBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_1wlap"), SubResource("Resource_ugjyq")])
variables = {
"active": {
"default": true,
"exported": true,
"type": "bool"
},
"base_alpha": {
"default": 1.0,
"exported": false,
"type": "float"
},
"base_captured": {
"default": false,
"exported": false,
"type": "bool"
},
"base_rotation": {
"default": 0.0,
"exported": false,
"type": "float"
},
"base_scale_x": {
"default": 1.0,
"exported": false,
"type": "float"
},
"base_scale_y": {
"default": 1.0,
"exported": false,
"type": "float"
},
"base_x": {
"default": 0.0,
"exported": false,
"type": "float"
},
"base_y": {
"default": 0.0,
"exported": false,
"type": "float"
},
"magnitude": {
"default": 50.0,
"exported": true,
"type": "float"
},
"movement": {
"default": "horizontal",
"exported": true,
"options": ["horizontal", "vertical", "forwards-backwards", "size", "angle", "opacity", "value-only"],
"type": "String"
},
"period": {
"default": 4.0,
"exported": true,
"type": "float"
},
"phase_degrees": {
"default": 0.0,
"exported": true,
"type": "float"
},
"time": {
"default": 0.0,
"exported": false,
"type": "float"
},
"wave": {
"default": "sine",
"exported": true,
"options": ["sine", "triangle", "sawtooth", "reverse-sawtooth", "square"],
"type": "String"
},
"wave_value": {
"default": 0.0,
"exported": false,
"type": "float"
}
}
functions = Array[Resource]([SubResource("Resource_ndxdi"), SubResource("Resource_oul26"), SubResource("Resource_cjqmc"), SubResource("Resource_hfdf0"), SubResource("Resource_uvkhb")])
