"type": "float"
},
"base_x": {
"default": 0.0,
"exported": false,
"type": "float"
},
"base_y": {
"default": 0.0,
"exported": false,
"type": "float"
},
"magnitude": {
"default": 50.0,
"exported": true,
"type": "float"
},
"movement": {
"default": "horizontal",
"exported": true,
"options": ["horizontal", "vertical", "forwards-backwards", "size", "angle", "opacity", "value-only"],
"type": "String"
},
"period": {
"default": 4.0,
"exported": true,
"type": "float"
},
"phase_degrees": {
"default": 0.0,
"exported": true,
"type": "float"
},
"time": {
"default": 0.0,
"exported": false,
"type": "float"
},
"wave": {
"default": "sine",
"exported": true,
"options": ["sine", "triangle", "sawtooth", "reverse-sawtooth", "square"],
"type": "String"
},
"wave_value": {
"default": 0.0,
"exported": false,
"type": "float"
}
}
