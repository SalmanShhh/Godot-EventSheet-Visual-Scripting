"active": {
"default": true,
"exported": true,
"type": "bool"
},
"base_alpha": {
"default": 1.0,
"exported": false,
"type": "float"
},
"base_captured": {
"default": false,
"exported": false,
"type": "bool"
},
"base_rotation": {
"default": 0.0,
"exported": false,
"type": "float"
},
