[sub_resource type="Resource" id="Resource_733ur"]
script = ExtResource("1_3x5jo")
text = "Sine behavior (C3 parity): wave-driven oscillation. movement: horizontal, vertical, forwards-backwards, size, angle, opacity, value-only. wave: sine, triangle, sawtooth, reverse-sawtooth, square. Read the current wave via $SineBehavior.wave_value."

[sub_resource type="Resource" id="Resource_81y13"]
script = ExtResource("2_6dloj")
code = "## @ace_hidden
func _wave(t: float) -> float:
	var cycle := fposmod(t, 1.0)
	match wave:
		\"triangle\":
			return 1.0 - 4.0 * absf(cycle - 0.5)
		\"sawtooth\":
			return 2.0 * cycle - 1.0
		\"reverse-sawtooth\":
			return 1.0 - 2.0 * cycle
		\"square\":
			return 1.0 if cycle < 0.5 else -1.0
	return sin(cycle * TAU)"

