[sub_resource type="Resource" id="Resource_052by"]
script = ExtResource("1_4oi2v")
text = "Sine behavior (C3-style): oscillates the host around its starting position/angle. movement: horizontal, vertical or angle."

[sub_resource type="Resource" id="Resource_4g6ho"]
script = ExtResource("2_3x5jo")
code = "if not active or host == null:
	return
if not base_captured:
	base_x = host.position.x
	base_y = host.position.y
	base_captured = true
time += delta
var offset := sin(time * TAU / period) * magnitude
if movement == \"horizontal\":
	host.position.x = base_x + offset
elif movement == \"vertical\":
	host.position.y = base_y + offset
elif movement == \"angle\":
	host.rotation = offset * 0.0174533"

[sub_resource type="Resource" id="Resource_733ur"]
script = ExtResource("6_brf4f")
trigger_provider_id = "Core"
trigger_id = "OnProcess"
actions = Array[Resource]([SubResource("Resource_4g6ho")])
event_uid = "d8eee4"

[sub_resource type="Resource" id="Resource_81y13"]
script = ExtResource("2_3x5jo")
code = "active = is_active"

[sub_resource type="Resource" id="Resource_1wlap"]
script = ExtResource("7_ma42h")
id = "is_active"
type_name = "bool"
initial_value = null
initialValue = null

[sub_resource type="Resource" id="Resource_2rghd"]
script = ExtResource("8_wp66b")
function_name = "set_sine_active"
description = "Pauses or resumes the oscillation."
expose_as_ace = true
ace_display_name = "Set Sine Active"
ace_category = "Sine"
params = Array[ExtResource("7_ma42h")]([SubResource("Resource_1wlap")])
events = Array[Resource]([SubResource("Resource_81y13")])

[sub_resource type="Resource" id="Resource_1s08y"]
script = ExtResource("2_3x5jo")
code = "time = 0.0
base_captured = false"

[sub_resource type="Resource" id="Resource_pkkss"]
script = ExtResource("8_wp66b")
function_name = "reset_sine"
description = "Restarts the wave from the current position."
expose_as_ace = true
ace_display_name = "Reset Sine"
ace_category = "Sine"
events = Array[Resource]([SubResource("Resource_1s08y")])

[resource]
script = ExtResource("9_lul5e")
