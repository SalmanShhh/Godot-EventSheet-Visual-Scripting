[sub_resource type="Resource" id="Resource_mcrq6"]
script = ExtResource("1_foqll")
text = "Top-down 8-direction movement: attach under a CharacterBody2D; moves with the ui_* input actions."

[sub_resource type="Resource" id="Resource_cd6x4"]
script = ExtResource("2_qu4da")
ace_id = "SetLocalVarTyped"
params = {
"name": "input_vector",
"value": "Input.get_vector(\"ui_left\", \"ui_right\", \"ui_up\", \"ui_down\")",
"var_type": "Vector2"
}

[sub_resource type="Resource" id="Resource_hnixl"]
script = ExtResource("2_qu4da")
ace_id = "SetVelocity2D"
params = {
"vel": "input_vector * move_speed"
}

[sub_resource type="Resource" id="Resource_w741j"]
script = ExtResource("2_qu4da")
ace_id = "MoveAndSlide"

[sub_resource type="Resource" id="Resource_bc0au"]
script = ExtResource("3_rbere")
ace_id = "IsValid"
params = {
"target": "host"
}

[sub_resource type="Resource" id="Resource_qp3ot"]
script = ExtResource("6_0yw3h")
trigger_provider_id = "Core"
trigger_id = "OnPhysicsProcess"
conditions = Array[ExtResource("3_rbere")]([SubResource("Resource_bc0au")])
actions = Array[Resource]([SubResource("Resource_cd6x4"), SubResource("Resource_hnixl"), SubResource("Resource_w741j")])
event_uid = "411f1c"

[sub_resource type="Resource" id="Resource_vnl70"]
script = ExtResource("2_qu4da")
ace_id = "SetVar"
params = {
"value": "speed",
"var_name": "move_speed"
}

[sub_resource type="Resource" id="Resource_fvd7x"]
script = ExtResource("6_0yw3h")
actions = Array[Resource]([SubResource("Resource_vnl70")])
event_uid = "4cc9e5"

[sub_resource type="Resource" id="Resource_l5lc4"]
script = ExtResource("7_hsu0o")
id = "speed"
type_name = "float"
initial_value = null
initialValue = null

[sub_resource type="Resource" id="Resource_2rcgr"]
script = ExtResource("8_1h4jf")
function_name = "set_move_speed"
description = "Changes the movement speed."
expose_as_ace = true
ace_display_name = "Set Move Speed"
ace_category = "Eight Direction"
params = Array[ExtResource("7_hsu0o")]([SubResource("Resource_l5lc4")])
events = Array[Resource]([SubResource("Resource_fvd7x")])

[resource]
script = ExtResource("9_a5hw0")
host_class = "CharacterBody2D"
behavior_mode = true
custom_class_name = "EightDirectionMovement"
addon_tags = PackedStringArray()
events = Array[Resource]([SubResource("Resource_mcrq6"), SubResource("Resource_qp3ot")])
variables = {
"move_speed": {
"default": 200.0,
"exported": true,
"type": "float"
}
}
functions = Array[Resource]([SubResource("Resource_2rcgr")])
