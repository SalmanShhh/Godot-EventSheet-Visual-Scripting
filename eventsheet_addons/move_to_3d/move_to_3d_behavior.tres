[sub_resource type="Resource" id="Resource_1pom0"]
script = ExtResource("1_qyv10")
text = "Move To 3D behavior (C3-style): glides through a queue of Vector3 waypoints and fires On Arrived at the final stop."

[sub_resource type="Resource" id="Resource_fkxun"]
script = ExtResource("2_rf12q")
code = "## @ace_trigger
## @ace_name(\"On Arrived (3D)\")
## @ace_category(\"Move To 3D\")
signal arrived"

[sub_resource type="Resource" id="Resource_bt8yp"]
script = ExtResource("2_rf12q")
code = "if not moving or host == null or waypoints.is_empty():
	return
var target: Vector3 = waypoints[0]
host.position = host.position.move_toward(target, max_speed * delta)
if host.position.distance_to(target) < 0.05:
	waypoints.pop_front()
	if waypoints.is_empty():
		moving = false
		arrived.emit()"

