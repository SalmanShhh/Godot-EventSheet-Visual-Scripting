[resource]
script = ExtResource("10_fkxun")
host_class = "Node3D"
behavior_mode = true
custom_class_name = "MoveTo3DBehavior"
addon_tags = PackedStringArray()
custom_class_icon = "res://eventsheet_addons/behavior.svg"
events = Array[Resource]([SubResource("Resource_bt8yp"), SubResource("Resource_6db6m"), SubResource("Resource_28wje")])
variables = {
"max_speed": {
"default": 5.0,
"exported": true,
"type": "float"
},
"moving": {
"default": false,
"exported": false,
"type": "bool"
},
"waypoints": {
"default": [],
"exported": false,
"type": "Array"
}
}
functions = Array[Resource]([SubResource("Resource_gnclx"), SubResource("Resource_r2s5o"), SubResource("Resource_0mxjw")])
