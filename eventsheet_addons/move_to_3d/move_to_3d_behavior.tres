[sub_resource type="Resource" id="Resource_bt8yp"]
script = ExtResource("1_rf12q")
text = "Move To 3D behavior (C3-style): glides through a queue of Vector3 waypoints and fires On Arrived at the final stop."

[sub_resource type="Resource" id="Resource_6db6m"]
script = ExtResource("2_a81oj")
signal_name = "arrived"
params = PackedStringArray()
trigger = true
ace_name = "On Arrived (3D)"
ace_category = "Move To 3D"

[sub_resource type="Resource" id="Resource_p4r2y"]
script = ExtResource("7_rk1jj")
ace_id = "ReturnEarly"

[sub_resource type="Resource" id="Resource_m6n13"]
script = ExtResource("3_pmih3")
ace_id = "DictIsEmpty"
params = {
"var_name": "not moving or host == null or waypoints"
}

[sub_resource type="Resource" id="Resource_ugdkg"]
script = ExtResource("6_ja3jk")
conditions = Array[ExtResource("3_pmih3")]([SubResource("Resource_m6n13")])
actions = Array[Resource]([SubResource("Resource_p4r2y")])
event_uid = "9b8874"

[sub_resource type="Resource" id="Resource_2rwcr"]
script = ExtResource("7_rk1jj")
ace_id = "SetLocalVarTyped"
params = {
"name": "target",
"value": "waypoints[0]",
"var_type": "Vector3"
}

[sub_resource type="Resource" id="Resource_rlwua"]
script = ExtResource("7_rk1jj")
ace_id = "SetPosition2D"
params = {
"pos": "host.position.move_toward(target, max_speed * delta)",
"target": "host"
}

[sub_resource type="Resource" id="Resource_ntf5i"]
script = ExtResource("6_ja3jk")
actions = Array[Resource]([SubResource("Resource_2rwcr"), SubResource("Resource_rlwua")])
event_uid = "31f72a"

[sub_resource type="Resource" id="Resource_0mf8w"]
script = ExtResource("7_rk1jj")
ace_id = "CallMethod"
params = {
"args": "",
"method": "pop_front",
"target": "waypoints"
}

[sub_resource type="Resource" id="Resource_1ph6y"]
script = ExtResource("3_pmih3")
ace_id = "CompareVar"
params = {
"op": "<",
"value": "0.05",
"var_name": "host.position.distance_to(target)"
}

[sub_resource type="Resource" id="Resource_1vtpb"]
script = ExtResource("7_rk1jj")
ace_id = "SetVar"
params = {
"value": "false",
"var_name": "moving"
}

[sub_resource type="Resource" id="Resource_nso4o"]
script = ExtResource("7_rk1jj")
ace_id = "EmitSignal"
params = {
"args": "",
"signal_name": "arrived"
}

[sub_resource type="Resource" id="Resource_6y0yy"]
script = ExtResource("3_pmih3")
