[sub_resource type="Resource" id="Resource_wlsfs"]
script = ExtResource("1_efx4g")
text = "Platformer movement behavior: attach under a CharacterBody2D. Move with ui_left/ui_right; call Jump from any sheet."

[sub_resource type="Resource" id="Resource_b2uae"]
script = ExtResource("2_7fivs")
code = "## @ace_trigger
## @ace_name(\"On Jumped\")
## @ace_category(\"Platformer\")
signal jumped"

[sub_resource type="Resource" id="Resource_3d0wo"]
script = ExtResource("2_7fivs")
code = "if host == null:
	return
var direction := Input.get_axis(\"ui_left\", \"ui_right\")
host.velocity.x = direction * move_speed
if not host.is_on_floor():
	host.velocity.y += gravity * delta
host.move_and_slide()"

[sub_resource type="Resource" id="Resource_4dex6"]
script = ExtResource("6_wybey")
trigger_provider_id = "Core"
trigger_id = "OnPhysicsProcess"
actions = Array[Resource]([SubResource("Resource_3d0wo")])
event_uid = "527b07"

[sub_resource type="Resource" id="Resource_dop18"]
script = ExtResource("2_7fivs")
code = "if host != null and host.is_on_floor():
	host.velocity.y = jump_velocity
	jumped.emit()"

[sub_resource type="Resource" id="Resource_ktl15"]
script = ExtResource("8_x0bpu")
function_name = "jump"
description = "Makes the host jump when it is on the floor."
expose_as_ace = true
ace_display_name = "Jump"
ace_category = "Platformer"
events = Array[Resource]([SubResource("Resource_dop18")])

[sub_resource type="Resource" id="Resource_f35s6"]
script = ExtResource("2_7fivs")
code = "move_speed = speed"

